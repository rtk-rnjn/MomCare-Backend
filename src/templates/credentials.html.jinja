{% extends "base.html.jinja" %}

{% block title %}Credentials{% endblock %}
{% block page_title %}Credentials{% endblock %}

{% block content %}

<div class="space-y-6">

    <!-- Filters -->
    <form method="get" class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

            <!-- Search -->
            <div class="md:col-span-2">
                <label class="block text-xs font-medium text-gray-500 mb-1">
                    Search
                </label>
                <input type="text" name="q" value="{{ q }}" placeholder="Email / Google ID / Apple ID"
                    class="w-full px-4 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500">
            </div>

            <!-- Provider -->
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">
                    Provider
                </label>
                <select name="provider" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500">
                    <option value="">All</option>
                    <option value="internal" {% if provider=="internal" %}selected{% endif %}>Internal</option>
                    <option value="google" {% if provider=="google" %}selected{% endif %}>Google</option>
                    <option value="apple" {% if provider=="apple" %}selected{% endif %}>Apple</option>
                </select>
            </div>

            <!-- Status -->
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">
                    Status
                </label>
                <select name="status" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500">
                    <option value="">All</option>
                    <option value="active" {% if status=="active" %}selected{% endif %}>Active</option>
                    <option value="locked" {% if status=="locked" %}selected{% endif %}>Locked</option>
                    <option value="deleted" {% if status=="deleted" %}selected{% endif %}>Deleted</option>
                </select>
            </div>

        </div>

        <!-- Footer row -->
        <div class="flex items-center justify-between mt-5 pt-4 border-t dark:border-gray-700">

            <div class="text-sm text-gray-500">
                Total records: <span class="font-medium">{{ total }}</span>
            </div>

            <div class="flex gap-2">

                <a href="{{ url_for('admin_credentials') }}" class="px-4 py-2 border rounded-md text-sm hover:bg-gray-50 dark:hover:bg-gray-700">
                    Reset
                </a>

                <button type="submit" class="px-5 py-2 bg-blue-600 text-white rounded-md text-sm hover:bg-blue-700">
                    Apply Filters
                </button>

            </div>
        </div>

    </form>

    <!-- Table -->
    <div class="bg-white dark:bg-gray-800 rounded shadow overflow-x-auto">

        <table class="min-w-full text-sm">

            <thead class="bg-gray-50 dark:bg-gray-700">
                <tr class="text-left">
                    <th class="px-4 py-3">ID</th>
                    <th class="px-4 py-3">Email</th>
                    <th class="px-4 py-3">Password Hash</th>
                    <th class="px-4 py-3">Providers</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Verified</th>
                    <th class="px-4 py-3">Last Login</th>
                    <th class="px-4 py-3">Created At</th>
                    <th class="px-4 py-3">Updated At</th>
                    <th class="px-4 py-3">Failed Login Count</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">

                {% for cred in credentials %}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">

                    <td class="px-4 py-3 font-mono text-xs">
                        {{ cred._id }}
                    </td>

                    <td class="px-4 py-3">
                        {{ cred.email_address or "-" }} <br>
                        {{ cred.email_address_normalized or "-" }} <br>
                        {% if cred.google_id %}
                        <span class="text-sm text-gray-500">Google ID: {{ cred.google_id }}</span><br>
                        {% endif %}
                        {% if cred.apple_id %}
                        <span class="text-sm text-gray-500">Apple ID: {{ cred.apple_id }}</span><br>
                        {% endif %}
                    </td>

                    <td class="px-4 py-3 font-mono text-xs">
                        {% if cred.password_algo %}
                        <span class="text-sm text-gray-500">{{ cred.password_algo }}</span>
                        {% endif %}
                        {{ cred.password_hash[:10] + "..." + cred.password_hash[-10:] if cred.password_hash else "-" }}
                    </td>

                    <td class="px-4 py-3">
                        {% if cred.authentication_providers %}
                        {{ cred.authentication_providers | join(", ") | title }}
                        {% else %}
                        -
                        {% endif %}
                    </td>

                    <td class="px-4 py-3 capitalize">
                        {{ cred.account_status or "-" }}
                        {% if cred.account_status == "locked" %}
                        <span class="ml-2 text-xs text-gray-500">
                        Locked until {{ cred.account_locked_until_timestamp | humanize_timestamp }}
                        </span>
                        {% endif %}
                        
                    </td>

                    <td class="px-4 py-3">
                        {% if cred.verified_email %}
                        <span class="text-green-600">Yes</span>
                        {% else %}
                        <span class="text-gray-400">No</span>
                        {% endif %}
                    </td>

                    <td class="px-4 py-3 text-xs">
                        {{ cred.last_login_timestamp | humanize_timestamp or "-" }}
                    </td>

                    <td class="px-4 py-3 text-xs">
                        {{ cred.created_at_timestamp | humanize_timestamp or "-" }}
                    </td>

                    <td class="px-4 py-3 text-xs">
                        {{ cred.updated_at_timestamp | humanize_timestamp or "-" }}
                    </td>

                    <td class="px-4 py-3 text-xs">
                        {% if cred.failed_login_attempts_timestamp and cred.failed_login_attempts %}
                            <span class="text-red-500">{{ cred.failed_login_attempts }} attempts</span>
                            (last at {{ cred.failed_login_attempts_timestamp | humanize_timestamp }})
                        {% elif cred.failed_login_attempts %}
                            <span class="text-red-500">{{ cred.failed_login_attempts }} attempts</span>
                        {% else %}
                            0 attempts
                        {% endif %}
                    </td>

                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-4 py-8 text-center text-gray-500">
                        No credentials found
                    </td>
                </tr>
                {% endfor %}

            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">

        <div class="text-sm text-gray-500">
            Page {{ page }} of {{ total_pages }}
        </div>

        <div class="flex gap-2">

            {% if page > 1 %}
            <a href="?page={{ page - 1 }}&q={{ q }}&provider={{ provider }}&status={{ status }}" class="px-3 py-1 border rounded">
                Prev
            </a>
            {% endif %}

            {% if page < total_pages %} <a href="?page={{ page + 1 }}&q={{ q }}&provider={{ provider }}&status={{ status }}" class="px-3 py-1 border rounded">
                Next
                </a>
                {% endif %}

        </div>
    </div>

</div>

{% endblock %}