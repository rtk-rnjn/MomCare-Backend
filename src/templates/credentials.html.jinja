{% extends "base.html.jinja" %}

{% block title %}Credentials{% endblock %}
{% block page_title %}Credentials{% endblock %}

{% block head %}
<style>
    /* ── FILTER FORM ── */
    .filter-form {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        animation: fadeInUp 0.3s ease both;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto auto;
        gap: 14px;
        align-items: end;
    }

    @media (max-width: 900px) {
        .filter-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 560px) {
        .filter-grid {
            grid-template-columns: 1fr;
        }
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field-label {

        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .field-input,
    .field-select {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        padding: 8px 12px;

        font-family: 'Instrument Sans', sans-serif;
        outline: none;
        transition: border-color 0.15s ease, color 0.15s ease;
        width: 100%;
    }

    .field-input::placeholder {
        color: var(--text-muted);
    }

    .field-input:focus,
    .field-select:focus {
        border-color: var(--border-accent);
        color: var(--text-primary);
    }

    .filter-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 10px;
    }

    .record-count {

        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
    }

    .record-count strong {
        color: var(--text-primary);
        font-weight: 600;
    }

    .filter-actions {
        display: flex;
        gap: 8px;
    }

    .btn-reset {
        padding: 7px 16px;
        border: 1px solid var(--border);
        border-radius: 7px;

        font-family: 'DM Mono', monospace;
        color: var(--text-secondary);
        background: var(--bg-elevated);
        text-decoration: none;
        cursor: pointer;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-reset:hover {
        border-color: var(--border-accent);
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    .btn-apply {
        padding: 7px 20px;
        border: 1px solid var(--accent);
        border-radius: 7px;

        font-family: 'DM Mono', monospace;
        color: #fff;
        background: var(--accent);
        cursor: pointer;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-apply:hover {
        background: #5254e7;
        border-color: #5254e7;
    }

    /* ── TABLE PANEL ── */
    .panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        animation: fadeInUp 0.4s ease both;
        margin-bottom: 20px;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;

    }

    .data-table thead tr {
        background: var(--bg-elevated);
    }

    .data-table th {
        padding: 11px 14px;
        text-align: left;

        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
        white-space: nowrap;
    }

    .data-table tbody tr {
        border-top: 1px solid var(--border);
        transition: background 0.12s ease;
    }

    .data-table tbody tr:hover {
        background: var(--bg-hover);
    }

    .data-table td {
        padding: 12px 14px;
        color: var(--text-secondary);
        vertical-align: top;
    }

    .mono {
        font-family: 'DM Mono', monospace;

        color: var(--text-muted);
    }

    .empty-row td {
        padding: 40px;
        text-align: center;
        color: var(--text-muted);
        font-style: italic;

    }

    /* ── CREDENTIAL CELL STYLES ── */
    .email-primary {

        color: var(--text-primary);
        font-weight: 500;
    }

    .email-normalized {

        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .social-id {

        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        margin-top: 3px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .social-badge {
        display: inline-block;
        padding: 1px 6px;
        border-radius: 4px;

        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .badge-google {
        background: rgba(66, 133, 244, 0.15);
        color: #4285f4;
        border: 1px solid rgba(66, 133, 244, 0.2);
    }

    .badge-apple {
        background: rgba(255, 255, 255, 0.07);
        color: #ccc;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    /* ── STATUS PILLS ── */
    .pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 9px;
        border-radius: 20px;

        font-family: 'DM Mono', monospace;
        letter-spacing: 0.04em;
        font-weight: 500;
    }

    .pill::before {
        content: '';
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .pill-active {
        background: rgba(34, 211, 160, 0.12);
        color: #22d3a0;
        border: 1px solid rgba(34, 211, 160, 0.2);
    }

    .pill-active::before {
        background: #22d3a0;
        box-shadow: 0 0 4px #22d3a0;
    }

    .pill-locked {
        background: rgba(245, 158, 11, 0.12);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .pill-locked::before {
        background: #f59e0b;
    }

    .pill-deleted {
        background: rgba(244, 63, 94, 0.12);
        color: #f43f5e;
        border: 1px solid rgba(244, 63, 94, 0.2);
    }

    .pill-deleted::before {
        background: #f43f5e;
    }

    .pill-default {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
        border: 1px solid var(--border);
    }

    .pill-default::before {
        background: var(--text-muted);
    }

    .pill-provider {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 5px;

        font-family: 'DM Mono', monospace;
        font-weight: 500;
        margin: 1px;
        background: var(--accent-subtle);
        color: #a5b4fc;
        border: 1px solid var(--border-accent);
    }

    .verified-yes {
        color: #22d3a0;

        .verified-no {
            color: var(--text-muted);

            .lock-note {
                display: block;

                font-family: 'DM Mono', monospace;
                color: var(--text-muted);
                margin-top: 4px;
            }

            .failed-attempts {
                color: #f43f5e;
                font-family: 'DM Mono', monospace;

            }

            .failed-ts {
                color: var(--text-muted);

                display: block;
                margin-top: 2px;
            }

            /* ── PAGINATION ── */
            .pagination {
                display: flex;
                align-items: center;
                justify-content: space-between;
                animation: fadeInUp 0.5s ease both;
                flex-wrap: wrap;
                gap: 10px;
            }

            .page-info {

                font-family: 'DM Mono', monospace;
                color: var(--text-muted);
            }

            .page-info strong {
                color: var(--text-secondary);
            }

            .page-btns {
                display: flex;
                gap: 6px;
            }

            .page-btn {
                padding: 6px 16px;
                border: 1px solid var(--border);
                border-radius: 7px;

                font-family: 'DM Mono', monospace;
                color: var(--text-secondary);
                background: var(--bg-surface);
                text-decoration: none;
                transition: all 0.15s ease;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

            .page-btn:hover {
                border-color: var(--border-accent);
                color: var(--text-primary);
                background: var(--bg-hover);
            }

            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(8px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
</style>
{% endblock %}

{% block content %}

<!-- ── FILTER FORM ── -->
<form method="get" class="filter-form">
    <div class="filter-grid">

        <div class="field-group" style="grid-column: span 2;">
            <label class="field-label">Search</label>
            <input type="text" name="q" value="{{ q }}" placeholder="Email / Google ID / Apple ID" class="field-input" />
        </div>

        <div class="field-group">
            <label class="field-label">Provider</label>
            <select name="provider" class="field-select">
                <option value="">All Providers</option>
                <option value="internal" {% if provider=="internal" %}selected{% endif %}>Internal</option>
                <option value="google" {% if provider=="google" %}selected{% endif %}>Google</option>
                <option value="apple" {% if provider=="apple" %}selected{% endif %}>Apple</option>
            </select>
        </div>

        <div class="field-group">
            <label class="field-label">Status</label>
            <select name="status" class="field-select">
                <option value="">All Statuses</option>
                <option value="active" {% if status=="active" %}selected{% endif %}>Active</option>
                <option value="locked" {% if status=="locked" %}selected{% endif %}>Locked</option>
                <option value="deleted" {% if status=="deleted" %}selected{% endif %}>Deleted</option>
            </select>
        </div>

    </div>

    <div class="filter-footer">
        <div class="record-count">
            Total records: <strong>{{ total }}</strong>
        </div>
        <div class="filter-actions">
            <a href="{{ url_for('admin_credentials') }}" class="btn-reset">↺ Reset</a>
            <button type="submit" class="btn-apply">⌕ Apply Filters</button>
        </div>
    </div>
</form>

<!-- ── TABLE ── -->
<div class="panel">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Email / Identity</th>
                    <th>Password Hash</th>
                    <th>Providers</th>
                    <th>Status</th>
                    <th>Verified</th>
                    <th>Last Login</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Failed Logins</th>
                </tr>
            </thead>
            <tbody>
                {% for cred in credentials %}
                <tr>

                    <td class="mono">{{ cred._id }}</td>

                    <td>
                        {% if cred.email_address %}
                        <div class="email-primary">{{ cred.email_address }}</div>
                        {% endif %}
                        {% if cred.email_address_normalized %}
                        <div class="email-normalized">{{ cred.email_address_normalized }}</div>
                        {% endif %}
                        {% if cred.apple_id %}
                        <div class="social-id">
                            <span class="social-badge badge-apple">Apple</span>
                            {{ cred.apple_id }}
                        </div>
                        {% endif %}
                    </td>

                    <td>
                        {% if cred.password_algo %}
                        <div style="font-size:10px; color:var(--text-muted); font-family:'DM Mono',monospace; margin-bottom:3px;">{{ cred.password_algo }}</div>
                        {% endif %}
                        <div class="mono">
                            {{ cred.password_hash[:10] + "…" + cred.password_hash[-10:] if cred.password_hash else "—" }}
                        </div>
                    </td>

                    <td>
                        {% if cred.authentication_providers %}
                        {% for p in cred.authentication_providers %}
                        <span class="pill-provider">{{ p | title }}</span>
                        {% endfor %}
                        {% else %}
                        <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                    <td>
                        {% set s = cred.account_status or "" %}
                        {% if s == "active" %}
                        <span class="pill pill-active">active</span>
                        {% elif s == "locked" %}
                        <span class="pill pill-locked">locked</span>
                        {% if cred.account_locked_until_timestamp %}
                        <span class="lock-note">until {{ cred.account_locked_until_timestamp | humanize_timestamp }}</span>
                        {% endif %}
                        {% elif s == "deleted" %}
                        <span class="pill pill-deleted">deleted</span>
                        {% elif s %}
                        <span class="pill pill-default">{{ s }}</span>
                        {% else %}
                        <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if cred.verified_email %}
                        <span class="verified-yes">✓ Yes</span>
                        {% else %}
                        <span class="verified-no">✗ No</span>
                        {% endif %}
                    </td>

                    <td class="mono">{{ cred.last_login_timestamp | humanize_timestamp or "—" }}</td>
                    <td class="mono">{{ cred.created_at_timestamp | humanize_timestamp or "—" }}</td>
                    <td class="mono">{{ cred.updated_at_timestamp | humanize_timestamp or "—" }}</td>

                    <td>
                        {% if cred.failed_login_attempts %}
                        <span class="failed-attempts">{{ cred.failed_login_attempts }} attempts</span>
                        {% if cred.failed_login_attempts_timestamp %}
                        <span class="failed-ts">last: {{ cred.failed_login_attempts_timestamp | humanize_timestamp }}</span>
                        {% endif %}
                        {% else %}
                        <span class="mono">0</span>
                        {% endif %}
                    </td>

                </tr>
                {% else %}
                <tr class="empty-row">
                    <td colspan="10">No credentials found</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ── PAGINATION ── -->
<div class="pagination">
    <div class="page-info">
        Page <strong>{{ page }}</strong> of <strong>{{ total_pages }}</strong>
    </div>
    <div class="page-btns">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ q }}&provider={{ provider }}&status={{ status }}" class="page-btn">← Prev</a>
        {% endif %}
        {% if page < total_pages %} <a href="?page={{ page + 1 }}&q={{ q }}&provider={{ provider }}&status={{ status }}" class="page-btn">Next →</a>
            {% endif %}
    </div>
</div>

{% endblock %}