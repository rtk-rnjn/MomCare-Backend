{% extends "base.html.jinja" %}

{% block title %}Songs{% endblock %}
{% block page_title %}Songs{% endblock %}

{% block content %}

<!-- Filters -->
<form method="get" class="bg-white dark:bg-gray-800 rounded-lg shadow p-5 mb-6">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

        <!-- Search -->
        <div class="md:col-span-2">
            <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
            <input type="text" name="q" value="{{ q }}" placeholder="Song name / Author / Title"
                class="w-full px-4 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500">
        </div>

        <!-- Mood -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Mood</label>
            <select name="mood" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900">
                <option value="">All</option>
                <option value="Happy" {% if mood=="Happy" %}selected{% endif %}>Happy</option>
                <option value="Sad" {% if mood=="Sad" %}selected{% endif %}>Sad</option>
                <option value="Stressed" {% if mood=="Stressed" %}selected{% endif %}>Stressed</option>
                <option value="Angry" {% if mood=="Angry" %}selected{% endif %}>Angry</option>
            </select>
        </div>

        <!-- Playlist -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Playlist</label>
            <input type="text" name="playlist" value="{{ playlist }}" placeholder="Playlist name" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900">
        </div>

    </div>

    <div class="flex items-center justify-between mt-5 pt-4 border-t dark:border-gray-700">
        <div class="text-sm text-gray-500">
            Total records: <span class="font-medium">{{ total }}</span>
        </div>

        <div class="flex gap-2">
            <a href="/songs" class="px-4 py-2 border rounded-md text-sm">Reset</a>
            <button type="submit" class="px-5 py-2 bg-blue-600 text-white rounded-md text-sm">Apply Filters</button>
        </div>
    </div>

</form>

<!-- Table -->
<div class="bg-white dark:bg-gray-800 rounded shadow overflow-x-auto">

    <table class="min-w-full text-sm">

        <thead class="bg-gray-50 dark:bg-gray-700">
            <tr class="text-left">
                <th class="px-4 py-3">ID</th>
                <th class="px-4 py-3">Song Name</th>
                <th class="px-4 py-3">Mood</th>
                <th class="px-4 py-3">Playlist</th>
                <th class="px-4 py-3">Author</th>
                <th class="px-4 py-3">Title</th>
                <th class="px-4 py-3">Duration (s)</th>
                <th class="px-4 py-3">Playlist Image</th>
                <th class="px-4 py-3">Song Image</th>
            </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">

            {% for s in songs %}
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3 font-mono text-xs">{{ s._id }}</td>
                <td class="px-4 py-3">{{ s.song_name }}</td>
                <td class="px-4 py-3 capitalize">{{ s.mood }}</td>
                <td class="px-4 py-3">{{ s.playlist }}</td>
                <td class="px-4 py-3">{{ s.metadata.author if s.metadata else "-" }}</td>
                <td class="px-4 py-3">{{ s.metadata.title if s.metadata else "-" }}</td>
                <td class="px-4 py-3">{{ s.metadata.duration if s.metadata else "-" }}</td>

                <td class="px-4 py-3">
                    {% if s.playlist_image_uri %}
                    <a href="{{ s.playlist_image_uri }}" target="_blank" class="text-blue-600 text-xs">View</a>
                    {% else %}
                    -
                    {% endif %}
                </td>

                <td class="px-4 py-3">
                    {% if s.song_image_uri %}
                    <a href="{{ s.song_image_uri }}" target="_blank" class="text-blue-600 text-xs">View</a>
                    {% else %}
                    -
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="9" class="px-4 py-8 text-center text-gray-500">
                    No songs found
                </td>
            </tr>
            {% endfor %}

        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="flex items-center justify-between mt-6">
    <div class="text-sm text-gray-500">
        Page {{ page }} of {{ total_pages }}
    </div>

    <div class="flex gap-2">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ q }}&mood={{ mood }}&playlist={{ playlist }}" class="px-3 py-1 border rounded">Prev</a>
        {% endif %}

        {% if page < total_pages %} <a href="?page={{ page + 1 }}&q={{ q }}&mood={{ mood }}&playlist={{ playlist }}" class="px-3 py-1 border rounded">Next</a>
            {% endif %}
    </div>
</div>

{% endblock %}