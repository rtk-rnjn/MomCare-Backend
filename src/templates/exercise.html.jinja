{% extends "base.html.jinja" %}

{% block title %}Exercises{% endblock %}
{% block page_title %}Exercises{% endblock %}

{% block content %}

<!-- Filters -->
<form method="get" class="bg-white dark:bg-gray-800 rounded-lg shadow p-5 mb-6">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

        <!-- Search -->
        <div class="md:col-span-2">
            <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
            <input type="text" name="q" value="{{ q }}" placeholder="Exercise name / Tags"
                class="w-full px-4 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500">
        </div>

        <!-- Level -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Level</label>
            <select name="level" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900">
                <option value="">All</option>
                <option value="Beginner" {% if level=="Beginner" %}selected{% endif %}>Beginner</option>
                <option value="Intermediate" {% if level=="Intermediate" %}selected{% endif %}>Intermediate</option>
                <option value="Advanced" {% if level=="Advanced" %}selected{% endif %}>Advanced</option>
            </select>
        </div>

        <!-- Week -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Week</label>
            <input type="text" name="week" value="{{ week }}" placeholder="e.g. Week 12" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900">
        </div>

    </div>

    <div class="flex items-center justify-between mt-5 pt-4 border-t dark:border-gray-700">
        <div class="text-sm text-gray-500">
            Total records: <span class="font-medium">{{ total }}</span>
        </div>

        <div class="flex gap-2">
            <a href="/exercise" class="px-4 py-2 border rounded-md text-sm">Reset</a>
            <button type="submit" class="px-5 py-2 bg-blue-600 text-white rounded-md text-sm">Apply Filters</button>
        </div>
    </div>

</form>

<!-- Table -->
<div class="bg-white dark:bg-gray-800 rounded shadow overflow-x-auto">

    <table class="min-w-full text-sm">

        <thead class="bg-gray-50 dark:bg-gray-700">
            <tr class="text-left">
                <th class="px-4 py-3">ID</th>
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3">Level</th>
                <th class="px-4 py-3">Week</th>
                <th class="px-4 py-3">Tags</th>
                <th class="px-4 py-3">Targeted Body Parts</th>
                <th class="px-4 py-3">Description</th>
                <th class="px-4 py-3">Image</th>
                <th class="px-4 py-3">Video Duration (s)</th>
            </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">

            {% for ex in exercises %}
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3 font-mono text-xs">{{ ex._id }}</td>
                <td class="px-4 py-3">{{ ex.name }}</td>
                <td class="px-4 py-3 capitalize">{{ ex.level }}</td>
                <td class="px-4 py-3">{{ ex.week }}</td>
                <td class="px-4 py-3 text-xs">{{ ex.tags | join(", ") if ex.tags else "-" }}</td>
                <td class="px-4 py-3 text-xs">{{ ex.targeted_body_parts | join(", ") if ex.targeted_body_parts else "-" }}</td>
                <td class="px-4 py-3 text-xs">{{ ex.description }}</td>
                <td class="px-4 py-3">
                    {% if ex.image_name_uri %}
                    <a href="{{ ex.image_name_uri }}" target="_blank" class="text-blue-600 text-xs">View</a>
                    {% else %}
                    -
                    {% endif %}
                </td>
                <td class="px-4 py-3">{{ ex.video_duration_seconds }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="9" class="px-4 py-8 text-center text-gray-500">
                    No exercises found
                </td>
            </tr>
            {% endfor %}

        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="flex items-center justify-between mt-6">
    <div class="text-sm text-gray-500">
        Page {{ page }} of {{ total_pages }}
    </div>

    <div class="flex gap-2">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ q }}&level={{ level }}&week={{ week }}" class="px-3 py-1 border rounded">Prev</a>
        {% endif %}

        {% if page < total_pages %} <a href="?page={{ page + 1 }}&q={{ q }}&level={{ level }}&week={{ week }}" class="px-3 py-1 border rounded">Next</a>
            {% endif %}
    </div>
</div>

{% endblock %}