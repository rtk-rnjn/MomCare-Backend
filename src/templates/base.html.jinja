<!DOCTYPE html>
<html lang="en"
    x-data="{ sidebarOpen: false, dark: localStorage.getItem('theme') ? localStorage.getItem('theme') === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches }"
    x-init="$watch('dark', value => localStorage.setItem('theme', value ? 'dark' : 'light'))" :class="{ 'dark': dark }">

<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin Dashboard{% endblock %}</title>
    <link rel="stylesheet" href="{{ url_for('static', path='output.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        :root {
            --bg-base: #f7f7f5;
            --bg-surface: #ffffff;
            --bg-elevated: #f1f2f4;
            --bg-hover: #e8e9ec;
            --border: #e2e4e8;
            --border-accent: #9abed1;
            --accent: #2d6a8f;
            --accent-glow: rgba(45, 106, 143, 0.12);
            --accent-subtle: rgba(45, 106, 143, 0.08);
            --text-primary: #1f2933;
            --text-secondary: #334155;
            --text-muted: #6b7280;
            --success: #2f855a;
            --warning: #c05621;
            --danger: #c53030;
            --sidebar-width: 240px;
        }

        .dark {
            --bg-base: #0f1720;
            --bg-surface: #131c26;
            --bg-elevated: #182433;
            --bg-hover: #1f2c3d;
            --border: rgba(255, 255, 255, 0.08);
            --border-accent: #4a90b7;
            --accent: #5ea3c4;
            --accent-glow: rgba(94, 163, 196, 0.18);
            --accent-subtle: rgba(94, 163, 196, 0.12);
            --text-primary: #f4f7fb;
            --text-secondary: #d7deea;
            --text-muted: #8fa0b4;
            --success: #48bb78;
            --warning: #f6ad55;
            --danger: #f56565;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bg-base);
            color: var(--text-primary);
            font-family: 'Instrument Sans', sans-serif;
            line-height: 1.6;
            min-height: 100vh;
        }

        .layout {
            display: flex;
            height: 100vh;
            overflow: hidden;
            position: relative;
            z-index: 1;
        }

        /* ── SIDEBAR ── */
        aside {
            width: var(--sidebar-width);
            background: var(--bg-surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 30;
        }

        .sidebar-brand {
            padding: 28px 20px 24px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-brand h1 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--text-primary);
        }

        .sidebar-brand p {

            font-family: 'DM Mono', monospace;
            color: var(--text-muted);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-top: 4px;
        }

        .sidebar-indicator {
            display: inline-block;
            width: 6px;
            height: 6px;
            background: var(--success);
            border-radius: 50%;
            margin-right: 6px;
            box-shadow: 0 0 8px var(--success);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }

        nav {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 2px;
            overflow-y: auto;
        }

        nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 8px;
            color: var(--text-secondary);
            text-decoration: none;

            font-weight: 500;
            transition: all 0.15s ease;
            position: relative;
        }

        nav a::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%) scaleY(0);
            width: 2px;
            height: 60%;
            background: var(--accent);
            border-radius: 2px;
            transition: transform 0.2s ease;
        }

        nav a:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        nav a:hover::before {
            transform: translateY(-50%) scaleY(1);
        }

        nav .nav-icon {
            width: 16px;
            height: 16px;
            opacity: 0.5;
        }

        nav a:hover .nav-icon {
            opacity: 1;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        /* ── MAIN AREA ── */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ── TOPBAR ── */
        header {
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border);
            padding: 0 24px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;

            letter-spacing: -0.01em;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-theme {
            padding: 6px 14px;

            font-family: 'DM Mono', monospace;
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.15s ease;
            letter-spacing: 0.02em;
        }

        .btn-theme:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
            border-color: var(--border-accent);
        }

        .admin-badge {

            font-family: 'DM Mono', monospace;
            color: var(--text-muted);
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: 0.05em;
        }

        .hamburger-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 6px;
            border-radius: 6px;

            transition: color 0.15s;
            display: none;
        }

        /* ── CONTENT ── */
        main {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
            scroll-behavior: smooth;
        }

        main::-webkit-scrollbar {
            width: 4px;
        }

        main::-webkit-scrollbar-track {
            background: transparent;
        }

        main::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }

        /* ── FLASH MESSAGES ── */
        .flash-msg {
            margin-bottom: 20px;
            padding: 12px 16px;
            border-radius: 8px;
            background: rgba(34, 211, 160, 0.1);
            border: 1px solid rgba(34, 211, 160, 0.3);
            color: var(--success);

        }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            aside {
                position: fixed;
                inset-y: 0;
                left: 0;
                transform: translateX(-100%);
            }

            aside.open {
                transform: translateX(0);
            }

            .hamburger-btn {
                display: flex;
            }
        }

        [x-cloak] {
            display: none !important;
        }
    </style>

    {% block head %}{% endblock %}
</head>

<body class="app-body">

    <div class="layout">

        <!-- SIDEBAR -->
        <aside :class="sidebarOpen ? 'open' : ''">

            <div class="sidebar-brand">
                <h1>MomCare+</h1>
                <p><span class="sidebar-indicator"></span>MomCare+ Backend</p>
            </div>

            <nav>
                <a href="{{ url_for('admin_dashboard') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h6v6H3zM3 15h6v4H3zM13 3h8v8h-8zM13 15h8v6h-8z" />
                    </svg>
                    Dashboard
                </a>
                <a href="{{ url_for('admin_logs') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    Logs
                </a>
                <a href="{{ url_for('admin_data_manager') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 7a2 2 0 012-2h12a2 2 0 012 2v0a2 2 0 01-2 2H6a2 2 0 01-2-2zm0 6a2 2 0 012-2h12a2 2 0 012 2v0a2 2 0 01-2 2H6a2 2 0 01-2-2zm0 6a2 2 0 012-2h12a2 2 0 012 2v0a2 2 0 01-2 2H6a2 2 0 01-2-2z" />
                    </svg>
                    Data Manager
                </a>
                <a href="{{ url_for('admin_users') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Users
                </a>
                <a href="{{ url_for('admin_credentials') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                    </svg>
                    Credentials
                </a>
                <a href="{{ url_for('admin_metrics') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    Metrics
                </a>
                <a href="{{ url_for('admin_audit_log') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    Audit Log
                </a>
                <a href="{{ url_for('admin_login_attempts') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                    Login Attempts
                </a>
                <a href="{{ url_for('admin_accounts') }}">
                    <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Admin Accounts
                </a>
            </nav>

            <div class="sidebar-footer">
                <div style="font-size:11px; color:var(--text-muted); font-family:'DM Mono',monospace; letter-spacing:0.05em;">v2.0 · INTERNAL USE</div>
            </div>

        </aside>

        <!-- MAIN AREA -->
        <div class="main-area">

            <!-- TOPBAR -->
            <header>
                <div class="topbar-left">
                    <button class="hamburger-btn" @click="sidebarOpen = !sidebarOpen">☰</button>
                    <h2 class="topbar-title">{% block page_title %}Dashboard{% endblock %}</h2>
                </div>

                <div class="topbar-right">
                    <button @click="dark = !dark" class="btn-theme" :aria-pressed="dark" x-text="dark ? 'Light theme' : 'Dark theme'"></button>
                    <span class="admin-badge">{{ request.session.get('admin_display_name', 'ADMIN') }} · {{ request.session.get('admin_role', '') }}</span>
                    <a href="{{ url_for('admin_logout') }}" style="font-size:12px; color:var(--text-muted); text-decoration:none; margin-left:8px;">Logout</a>
                </div>
            </header>

            <!-- CONTENT -->
            <main>
                {% if request.query_params.get("msg") %}
                <div class="flash-msg">
                    ✓ {{ request.query_params.get("msg") }}
                </div>
                {% endif %}

                {% block content %}{% endblock %}
            </main>

        </div>
    </div>

    {% block scripts %}{% endblock %}

</body>

</html>