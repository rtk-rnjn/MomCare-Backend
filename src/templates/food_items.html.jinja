{% extends "base.html.jinja" %}

{% block title %}Food Items{% endblock %}
{% block page_title %}Food Items{% endblock %}

{% block head %}
<style>
    .filter-form {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        animation: fadeInUp 0.3s ease both;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto auto;
        gap: 14px;
        align-items: end;
    }

    @media (max-width: 900px) { .filter-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 560px) { .filter-grid { grid-template-columns: 1fr; } }

    .field-group { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .field-input, .field-select {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        padding: 8px 12px;
        font-size: 13px;
        font-family: 'Instrument Sans', sans-serif;
        outline: none;
        transition: border-color 0.15s ease, color 0.15s ease;
        width: 100%;
    }

    .field-input::placeholder { color: var(--text-muted); }
    .field-input:focus, .field-select:focus {
        border-color: var(--border-accent);
        color: var(--text-primary);
    }

    .filter-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 10px;
    }

    .record-count {
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
    }

    .record-count strong { color: var(--text-primary); font-weight: 600; }

    .filter-actions { display: flex; gap: 8px; }

    .btn-reset {
        padding: 7px 16px;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-secondary);
        background: var(--bg-elevated);
        text-decoration: none;
        cursor: pointer;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-reset:hover {
        border-color: var(--border-accent);
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    .btn-apply {
        padding: 7px 20px;
        border: 1px solid var(--accent);
        border-radius: 7px;
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: #fff;
        background: var(--accent);
        cursor: pointer;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-apply:hover { background: #5254e7; border-color: #5254e7; }

    /* ── TABLE ── */
    .panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        animation: fadeInUp 0.4s ease both;
        margin-bottom: 20px;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .data-table thead tr { background: var(--bg-elevated); }

    .data-table th {
        padding: 11px 14px;
        text-align: left;
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
        white-space: nowrap;
    }

    .data-table tbody tr {
        border-top: 1px solid var(--border);
        transition: background 0.12s ease;
    }

    .data-table tbody tr:hover { background: var(--bg-hover); }

    .data-table td {
        padding: 12px 14px;
        color: var(--text-secondary);
        vertical-align: top;
    }

    .mono {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
    }

    .empty-row td {
        padding: 40px;
        text-align: center;
        color: var(--text-muted);
        font-style: italic;
    }

    /* ── FOOD NAME ── */
    .food-name {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 13px;
        white-space: nowrap;
    }

    /* ── TYPE PILLS ── */
    .pill {
        display: inline-block;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        letter-spacing: 0.04em;
        font-weight: 500;
        white-space: nowrap;
    }

    .pill-veg     { background: rgba(34,211,160,0.12); color: #22d3a0; border: 1px solid rgba(34,211,160,0.2); }
    .pill-vegan   { background: rgba(99,102,241,0.12); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.2); }
    .pill-nonveg  { background: rgba(244,63,94,0.12);  color: #f43f5e; border: 1px solid rgba(244,63,94,0.2); }
    .pill-default { background: rgba(255,255,255,0.05); color: var(--text-muted); border: 1px solid var(--border); }

    /* ── NUTRITION CELL ── */
    .nutrient-val {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    .nutrient-unit {
        font-size: 9px;
        color: var(--text-muted);
        margin-left: 2px;
    }

    /* ── TAG CHIPS ── */
    .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 3px;
        max-width: 160px;
    }

    .tag {
        display: inline-block;
        padding: 1px 6px;
        border-radius: 4px;
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        background: rgba(255,255,255,0.05);
        color: var(--text-muted);
        border: 1px solid var(--border);
        white-space: nowrap;
    }

    .tag-allergen {
        background: rgba(245,158,11,0.08);
        color: #f59e0b;
        border: 1px solid rgba(245,158,11,0.2);
    }

    .tag-vitamin {
        background: rgba(99,102,241,0.08);
        color: #818cf8;
        border: 1px solid rgba(99,102,241,0.15);
    }

    /* ── VIEW LINK ── */
    .view-link {
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        color: var(--accent);
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .view-link:hover { opacity: 0.7; }

    /* ── PAGINATION ── */
    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        animation: fadeInUp 0.5s ease both;
        flex-wrap: wrap;
        gap: 10px;
    }

    .page-info {
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
    }

    .page-info strong { color: var(--text-secondary); }
    .page-btns { display: flex; gap: 6px; }

    .page-btn {
        padding: 6px 16px;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-secondary);
        background: var(--bg-surface);
        text-decoration: none;
        transition: all 0.15s ease;
    }

    .page-btn:hover {
        border-color: var(--border-accent);
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}

{% block content %}

<!-- ── FILTER FORM ── -->
<form method="get" class="filter-form">
    <div class="filter-grid">

        <div class="field-group" style="grid-column: span 2;">
            <label class="field-label">Search</label>
            <input type="text" name="q" value="{{ q }}"
                placeholder="Search food items…"
                class="field-input" />
        </div>

        <div class="field-group">
            <label class="field-label">State</label>
            <input type="text" name="state" value="{{ state }}"
                placeholder="e.g. Delhi"
                class="field-input" />
        </div>

        <div class="field-group">
            <label class="field-label">Type</label>
            <select name="food_type" class="field-select">
                <option value="">All Types</option>
                <option value="veg"     {% if food_type=="veg"     %}selected{% endif %}>Veg</option>
                <option value="vegan"   {% if food_type=="vegan"   %}selected{% endif %}>Vegan</option>
                <option value="non-veg" {% if food_type=="non-veg" %}selected{% endif %}>Non-Veg</option>
            </select>
        </div>

    </div>

    <div class="filter-footer">
        <div class="record-count">
            Total records: <strong>{{ total }}</strong>
        </div>
        <div class="filter-actions">
            <a href="{{ url_for('admin_food_items') }}" class="btn-reset">↺ Reset</a>
            <button type="submit" class="btn-apply">⌕ Apply Filters</button>
        </div>
    </div>
</form>

<!-- ── TABLE ── -->
<div class="panel">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>State</th>
                    <th>Type</th>
                    <th>Calories</th>
                    <th>Carbs</th>
                    <th>Fats</th>
                    <th>Protein</th>
                    <th>Sugar</th>
                    <th>Sodium</th>
                    <th>Allergens</th>
                    <th>Vitamins</th>
                    <th>Image</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>

                    <td class="mono">{{ item._id }}</td>

                    <td>
                        <span class="food-name">{{ item.name }}</span>
                    </td>

                    <td>
                        <span style="font-size:13px; color:var(--text-secondary); text-transform:capitalize;">
                            {{ item.state or "—" }}
                        </span>
                    </td>

                    <td>
                        {% set t = item.type | lower if item.type else "" %}
                        {% if t == "veg" %}
                            <span class="pill pill-veg">Veg</span>
                        {% elif t == "vegan" %}
                            <span class="pill pill-vegan">Vegan</span>
                        {% elif t in ["non-veg", "nonveg"] %}
                            <span class="pill pill-nonveg">Non-Veg</span>
                        {% elif item.type %}
                            <span class="pill pill-default">{{ item.type }}</span>
                        {% else %}
                            <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if item.total_calories is not none %}
                        <span class="nutrient-val">{{ item.total_calories }}<span class="nutrient-unit">kcal</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.total_carbs_in_g is not none %}
                        <span class="nutrient-val">{{ item.total_carbs_in_g }}<span class="nutrient-unit">g</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.total_fats_in_g is not none %}
                        <span class="nutrient-val">{{ item.total_fats_in_g }}<span class="nutrient-unit">g</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.total_protein_in_g is not none %}
                        <span class="nutrient-val">{{ item.total_protein_in_g }}<span class="nutrient-unit">g</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.total_sugar_in_g is not none %}
                        <span class="nutrient-val">{{ item.total_sugar_in_g }}<span class="nutrient-unit">g</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.total_sodium_in_mg is not none %}
                        <span class="nutrient-val">{{ item.total_sodium_in_mg }}<span class="nutrient-unit">mg</span></span>
                        {% else %}<span style="color:var(--text-muted);">—</span>{% endif %}
                    </td>

                    <td>
                        {% if item.allergic_ingredients %}
                        <div class="tag-list">
                            {% for a in item.allergic_ingredients %}
                            <span class="tag tag-allergen">{{ a | title }}</span>
                            {% endfor %}
                        </div>
                        {% else %}
                        <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if item.vitamin_content %}
                        <div class="tag-list">
                            {% for v in item.vitamin_content %}
                            <span class="tag tag-vitamin">{{ v | title }}</span>
                            {% endfor %}
                        </div>
                        {% else %}
                        <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if item.image_uri %}
                        <a href="{{ item.image_uri }}" target="_blank" class="view-link">↗ View</a>
                        {% else %}
                        <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </td>

                </tr>
                {% else %}
                <tr class="empty-row">
                    <td colspan="13">No food items found</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ── PAGINATION ── -->
<div class="pagination">
    <div class="page-info">
        Page <strong>{{ page }}</strong> of <strong>{{ total_pages }}</strong>
    </div>
    <div class="page-btns">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ q }}&state={{ state }}&food_type={{ food_type }}" class="page-btn">← Prev</a>
        {% endif %}
        {% if page < total_pages %}
        <a href="?page={{ page + 1 }}&q={{ q }}&state={{ state }}&food_type={{ food_type }}" class="page-btn">Next →</a>
        {% endif %}
    </div>
</div>

{% endblock %}