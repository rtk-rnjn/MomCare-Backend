{% extends "base.html.jinja" %}

{% block title %}Food Items{% endblock %}
{% block page_title %}Food Items{% endblock %}

{% block content %}

<!-- Filters -->
<form method="get" class="bg-white dark:bg-gray-800 rounded-lg shadow p-5 mb-6">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

        <!-- Search -->
        <div class="md:col-span-2">
            <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
            <input
                type="text"
                name="q"
                value="{{ q }}"
                placeholder="Search food..."
                class="w-full px-4 py-2 border rounded-md dark:bg-gray-900 focus:ring-2 focus:ring-blue-500"
            >
        </div>

        <!-- State -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">State</label>
            <input
                type="text"
                name="state"
                value="{{ state }}"
                placeholder="e.g. delhi"
                class="w-full px-3 py-2 border rounded-md dark:bg-gray-900"
            >
        </div>

        <!-- Type -->
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Type</label>
            <select name="food_type" class="w-full px-3 py-2 border rounded-md dark:bg-gray-900">
                <option value="">All</option>
                <option value="veg" {% if food_type=="veg" %}selected{% endif %}>Veg</option>
                <option value="vegan" {% if food_type=="vegan" %}selected{% endif %}>Vegan</option>
                <option value="non-veg" {% if food_type=="non-veg" %}selected{% endif %}>Non-Veg</option>
            </select>
        </div>

    </div>

    <div class="flex items-center justify-between mt-5 pt-4 border-t dark:border-gray-700">
        <div class="text-sm text-gray-500">
            Total records: <span class="font-medium">{{ total }}</span>
        </div>

        <div class="flex gap-2">
            <a href="{{ url_for('admin_food_items') }}" class="px-4 py-2 border rounded-md text-sm">Reset</a>
            <button type="submit" class="px-5 py-2 bg-blue-600 text-white rounded-md text-sm">
                Apply Filters
            </button>
        </div>
    </div>

</form>

<!-- Table -->
<div class="bg-white dark:bg-gray-800 rounded shadow overflow-x-auto">

<table class="min-w-full text-sm">

    <thead class="bg-gray-50 dark:bg-gray-700">
        <tr class="text-left">
            <th class="px-4 py-3">ID</th>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">State</th>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Calories</th>
            <th class="px-4 py-3">Carbs</th>
            <th class="px-4 py-3">Fats</th>
            <th class="px-4 py-3">Protein</th>
            <th class="px-4 py-3">Sugar</th>
            <th class="px-4 py-3">Sodium</th>
            <th class="px-4 py-3">Allergens</th>
            <th class="px-4 py-3">Vitamins</th>
            <th class="px-4 py-3">Image</th>
        </tr>
    </thead>

    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">

    {% for item in items %}
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">

            <td class="px-4 py-3 font-mono text-xs">{{ item._id }}</td>
            <td class="px-4 py-3">{{ item.name }}</td>
            <td class="px-4 py-3 capitalize">{{ item.state }}</td>
            <td class="px-4 py-3 capitalize">{{ item.type }}</td>

            <td class="px-4 py-3">{{ item.total_calories }}</td>
            <td class="px-4 py-3">{{ item.total_carbs_in_g }}</td>
            <td class="px-4 py-3">{{ item.total_fats_in_g }}</td>
            <td class="px-4 py-3">{{ item.total_protein_in_g }}</td>
            <td class="px-4 py-3">{{ item.total_sugar_in_g }}</td>
            <td class="px-4 py-3">{{ item.total_sodium_in_mg }}</td>

            <td class="px-4 py-3 text-xs">
                {{ item.allergic_ingredients | join(", ") | title if item.allergic_ingredients else "-" }}
            </td>

            <td class="px-4 py-3 text-xs">
                {{ item.vitamin_content | join(", ") | title if item.vitamin_content else "-" }}
            </td>

            <td class="px-4 py-3">
                {% if item.image_uri %}
                    <a href="{{ item.image_uri }}" target="_blank" class="text-blue-600 text-xs">View</a>
                {% else %}
                    -
                {% endif %}
            </td>

        </tr>
    {% else %}
        <tr>
            <td colspan="13" class="px-4 py-8 text-center text-gray-500">
                No food items found
            </td>
        </tr>
    {% endfor %}

    </tbody>
</table>
</div>

<!-- Pagination -->
<div class="flex items-center justify-between mt-6">

    <div class="text-sm text-gray-500">
        Page {{ page }} of {{ total_pages }}
    </div>

    <div class="flex gap-2">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ q }}&state={{ state }}&food_type={{ food_type }}"
           class="px-3 py-1 border rounded">Prev</a>
        {% endif %}

        {% if page < total_pages %}
        <a href="?page={{ page + 1 }}&q={{ q }}&state={{ state }}&food_type={{ food_type }}"
           class="px-3 py-1 border rounded">Next</a>
        {% endif %}
    </div>

</div>

{% endblock %}