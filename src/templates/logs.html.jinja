{% extends "base.html.jinja" %}

{% block title %}Logs{% endblock %}
{% block page_title %}Logs{% endblock %}

{% block head %}
<style>
    /* ── TOOLBAR ── */
    .log-panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 140px);
    }

    .panel-header {
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        justify-content: space-between;
        background: linear-gradient(to right, rgba(99,102,241,0.04), transparent);
        flex-shrink: 0;
    }

    .panel-title-area {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .panel-title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 15px;
    }

    .live-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--success);
        padding: 3px 8px;
        background: rgba(34,211,160,0.08);
        border: 1px solid rgba(34,211,160,0.25);
        border-radius: 99px;
    }

    .live-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: var(--success);
        box-shadow: 0 0 5px var(--success);
        animation: blink 1.4s ease-in-out infinite;
    }

    .paused-indicator {
        display: none;
        align-items: center;
        gap: 5px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--warning);
        padding: 3px 8px;
        background: rgba(245,158,11,0.08);
        border: 1px solid rgba(245,158,11,0.25);
        border-radius: 99px;
    }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .log-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .filter-label {
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .filter-input, .filter-select {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 7px;
        color: var(--text-secondary);
        padding: 6px 10px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .filter-input:focus, .filter-select:focus {
        border-color: var(--border-accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.08);
        color: var(--text-primary);
    }

    .btn {
        padding: 6px 12px;
        border-radius: 7px;
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        color: var(--text-secondary);
        cursor: pointer;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        transition: all 0.15s ease;
        letter-spacing: 0.02em;
    }

    .btn:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border-accent); }
    .btn-danger { background: rgba(244,63,94,0.1); border-color: rgba(244,63,94,0.35); color: #fda4af; }
    .btn-pause  { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: #fcd34d; }

    /* ── STATS BAR ── */
    .stats-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 8px 18px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-elevated);
        flex-shrink: 0;
        flex-wrap: wrap;
    }

    .stat-chip {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        display: flex;
        align-items: center;
        gap: 5px;
        color: var(--text-muted);
    }

    .stat-chip strong { color: var(--text-secondary); }

    /* ── VIRTUAL SCROLL ── */
    .log-stream-wrap {
        flex: 1;
        overflow: hidden;
        position: relative;
        background: #09090f;
    }

    .log-stream {
        position: absolute;
        inset: 0;
        overflow-y: auto;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
    }

    .log-stream::-webkit-scrollbar { width: 4px; }
    .log-stream::-webkit-scrollbar-track { background: transparent; }
    .log-stream::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .virtual-spacer-top, .virtual-spacer-bottom {
        width: 100%;
        background: transparent;
        pointer-events: none;
    }

    /* ── LOG ROW ── */
    .log-row {
        display: flex;
        align-items: flex-start;
        gap: 0;
        padding: 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.1s;
        cursor: pointer;
        min-height: 30px;
    }

    .log-row:hover { background: rgba(255,255,255,0.03); }
    .log-row.expanded { background: rgba(99,102,241,0.04); border-color: rgba(99,102,241,0.15); }

    .log-gutter {
        width: 4px;
        align-self: stretch;
        flex-shrink: 0;
        border-radius: 0;
    }

    .log-main {
        flex: 1;
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 7px 14px 7px 10px;
        min-width: 0;
    }

    .log-level-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 3px;
        letter-spacing: 0.06em;
        flex-shrink: 0;
        width: 62px;
        text-align: center;
    }

    .log-ts {
        color: var(--text-muted);
        font-size: 11px;
        flex-shrink: 0;
        width: 84px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding-top: 1px;
    }

    .log-body {
        flex: 1;
        min-width: 0;
    }

    .log-message {
        color: var(--text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.5;
    }

    .log-row.expanded .log-message {
        white-space: normal;
        overflow: visible;
    }

    .log-meta-line {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 2px;
    }

    .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 10px;
        color: var(--text-muted);
    }

    .meta-chip .key { color: rgba(165,180,252,0.6); }

    /* ── LEVEL STYLES ── */
    .lvl-DEBUG    { background: rgba(107,114,128,0.15); color: #9ca3af; }
    .gutter-DEBUG { background: #374151; }

    .lvl-INFO     { background: rgba(99,102,241,0.15); color: #a5b4fc; }
    .gutter-INFO  { background: #6366f1; }

    .lvl-WARNING  { background: rgba(245,158,11,0.15); color: #fcd34d; }
    .gutter-WARNING { background: #d97706; }

    .lvl-ERROR    { background: rgba(244,63,94,0.18); color: #fda4af; }
    .gutter-ERROR { background: #f43f5e; }

    .lvl-CRITICAL { background: rgba(244,63,94,0.3); color: #fecdd3; }
    .gutter-CRITICAL { background: #f43f5e; }

    /* ── EXPANDED DETAIL ── */
    .log-detail {
        display: none;
        padding: 10px 14px 12px 118px;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .log-row.expanded .log-detail { display: block; }

    /* ── MONGO LOG ── */
    .mongo-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        margin-top: 6px;
    }

    .mongo-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
        background: rgba(99,102,241,0.05);
        flex-wrap: wrap;
    }

    .mongo-badge {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        padding: 2px 7px;
        border-radius: 3px;
        font-weight: 700;
        background: rgba(99,102,241,0.2);
        border: 1px solid rgba(99,102,241,0.4);
        color: #c7d2fe;
        letter-spacing: 0.05em;
    }

    .mongo-host {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-secondary);
    }

    .mongo-duration {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        margin-left: auto;
    }

    .mongo-duration.fast  { color: var(--success); }
    .mongo-duration.slow  { color: var(--warning); }
    .mongo-duration.vslow { color: var(--danger); }

    .mongo-card-body {
        padding: 10px 12px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 8px;
    }

    .mongo-field {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .mongo-field-key {
        font-size: 10px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .mongo-field-val {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-secondary);
        word-break: break-all;
    }

    /* ── EXCEPTION ── */
    .exception-block {
        background: rgba(244,63,94,0.06);
        border: 1px solid rgba(244,63,94,0.2);
        border-radius: 8px;
        padding: 10px 12px;
        margin-top: 6px;
        color: #fda4af;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 11px;
        line-height: 1.6;
    }

    /* ── GENERIC JSON ── */
    .json-block {
        background: rgba(0,0,0,0.3);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        margin-top: 6px;
        overflow: auto;
        max-height: 260px;
        font-size: 11px;
        line-height: 1.7;
        color: var(--text-secondary);
    }

    /* ── EMPTY / OVERFLOW MSG ── */
    .stream-msg {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
        font-family: 'DM Mono', monospace;
        font-size: 13px;
        color: var(--text-muted);
        gap: 8px;
    }

    .overflow-notice {
        display: none;
        align-items: center;
        gap: 8px;
        padding: 6px 18px;
        border-bottom: 1px solid rgba(245,158,11,0.2);
        background: rgba(245,158,11,0.05);
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--warning);
        flex-shrink: 0;
    }
</style>
{% endblock %}

{% block content %}
<div class="log-panel">
    <!-- TOOLBAR -->
    <div class="panel-header">
        <div class="panel-title-area">
            <span class="panel-title">Live Logs</span>
            <span class="live-indicator" id="liveIndicator">
                <span class="live-dot"></span>LIVE
            </span>
            <span class="paused-indicator" id="pausedIndicator">
                ⏸ PAUSED
            </span>
        </div>
        <div class="log-toolbar">
            <span class="filter-label">Level</span>
            <select id="logLevelFilter" class="filter-select">
                <option value="ALL">All</option>
                <option value="DEBUG">Debug</option>
                <option value="INFO">Info</option>
                <option value="WARNING">Warning</option>
                <option value="ERROR">Error</option>
                <option value="CRITICAL">Critical</option>
            </select>
            <span class="filter-label">Logger</span>
            <select id="loggerFilter" class="filter-select" style="max-width:160px;">
                <option value="ALL">All</option>
            </select>
            <span class="filter-label">Window</span>
            <select id="logDurationFilter" class="filter-select">
                <option value="all">All time</option>
                <option value="60">Last 1m</option>
                <option value="300">Last 5m</option>
                <option value="900">Last 15m</option>
                <option value="3600">Last 1h</option>
            </select>
            <input id="logSearchFilter" class="filter-input" placeholder="Search logs…" style="width:160px;" />
            <button id="pauseBtn" class="btn btn-pause">⏸ Pause</button>
            <button id="clearBtn" class="btn btn-danger">✕ Clear</button>
        </div>
    </div>

    <!-- OVERFLOW NOTICE -->
    <div class="overflow-notice" id="overflowNotice">
        ⚠ Buffer capped at <span id="capNoticeCount"></span> entries — oldest logs dropped. Clear to reset.
    </div>

    <!-- STATS BAR -->
    <div class="stats-bar">
        <div class="stat-chip">Buffered <strong id="statTotal">0</strong></div>
        <div class="stat-chip">Visible <strong id="statVisible">0</strong></div>
        <div class="stat-chip">Error <strong id="statError" style="color:#fda4af;">0</strong></div>
        <div class="stat-chip">Warn <strong id="statWarn" style="color:#fcd34d;">0</strong></div>
        <div class="stat-chip" style="margin-left:auto;">
            <span id="wsStatus" style="color:var(--text-muted);">● Connecting</span>
        </div>
    </div>

    <!-- VIRTUAL SCROLL CONTAINER -->
    <div class="log-stream-wrap">
        <div class="log-stream" id="logStream">
            <div class="stream-msg" id="emptyMsg">Waiting for logs…</div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
/* ═══════════════════════════════════════════════════════════
   CONFIG
═══════════════════════════════════════════════════════════ */
const MAX_BUFFER   = 2000;   // total log entries kept in memory
const RENDER_ROWS  = 80;     // DOM rows to render at a time
const ROW_HEIGHT   = 30;     // estimated px per collapsed row
const RENDER_THROTTLE = 80;  // ms — debounce re-renders

// Track which filteredBuf index each rendered DOM row corresponds to
// so we can do in-place expand without a full re-render
const renderedRows = new Map(); // idx -> DOM element

/* ═══════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════ */
let logBuffer    = [];
let filteredBuf  = [];
let isPaused     = false;
let autoScroll   = true;
let expandedIdx  = null;     // index in filteredBuf
let scrollTop    = 0;
let renderTimer  = null;
let filterTimer  = null;
let renderPending = false;

const knownLoggers = new Set(['ALL']);

/* ═══════════════════════════════════════════════════════════
   DOM REFS
═══════════════════════════════════════════════════════════ */
const stream       = document.getElementById('logStream');
const emptyMsg     = document.getElementById('emptyMsg');
const levelFilter  = document.getElementById('logLevelFilter');
const loggerFilter = document.getElementById('loggerFilter');
const searchFilter = document.getElementById('logSearchFilter');
const durFilter    = document.getElementById('logDurationFilter');
const pauseBtn     = document.getElementById('pauseBtn');
const clearBtn     = document.getElementById('clearBtn');
const liveInd      = document.getElementById('liveIndicator');
const pausedInd    = document.getElementById('pausedIndicator');
const overflowNotice = document.getElementById('overflowNotice');
const capNoticeCount = document.getElementById('capNoticeCount');
const statTotal    = document.getElementById('statTotal');
const statVisible  = document.getElementById('statVisible');
const statError    = document.getElementById('statError');
const statWarn     = document.getElementById('statWarn');
const wsStatus     = document.getElementById('wsStatus');

/* ═══════════════════════════════════════════════════════════
   FILTER
═══════════════════════════════════════════════════════════ */
function applyFilter() {
    const lvl    = levelFilter.value;
    const logger = loggerFilter.value;
    const q      = (searchFilter.value || '').trim().toLowerCase();
    const dur    = durFilter.value;
    const now    = Date.now();

    filteredBuf = logBuffer.filter(e => {
        if (lvl !== 'ALL' && e.level !== lvl) return false;
        if (logger !== 'ALL' && (e.logger_name || '-') !== logger) return false;
        if (dur !== 'all') {
            const ts = Date.parse(e.timestamp || '');
            if (isNaN(ts) || (now - ts) > Number(dur) * 1000) return false;
        }
        if (q) {
            const blob = `${e.message||''} ${e.path||''} ${e.method||''} ${e.logger_name||''} ${e.exception||''}`.toLowerCase();
            if (!blob.includes(q)) return false;
        }
        return true;
    });

    updateStats();
    scheduleRender();
}

function scheduleFilter() {
    clearTimeout(filterTimer);
    filterTimer = setTimeout(applyFilter, 120);
}

/* ═══════════════════════════════════════════════════════════
   STATS
═══════════════════════════════════════════════════════════ */
function updateStats() {
    statTotal.textContent   = logBuffer.length;
    statVisible.textContent = filteredBuf.length;
    let errs = 0, warns = 0;
    logBuffer.forEach(e => {
        if (e.level === 'ERROR' || e.level === 'CRITICAL') errs++;
        if (e.level === 'WARNING') warns++;
    });
    statError.textContent = errs;
    statWarn.textContent  = warns;
}

/* ═══════════════════════════════════════════════════════════
   RENDER ENGINE — virtual window
═══════════════════════════════════════════════════════════ */
function scheduleRender(force = false) {
    if (force) {
        clearTimeout(renderTimer);
        renderTimer = null;
        doRender();
        return;
    }
    if (renderTimer) return;
    renderTimer = setTimeout(() => {
        renderTimer = null;
        doRender();
    }, RENDER_THROTTLE);
}

function doRender() {
    const total = filteredBuf.length;

    emptyMsg.style.display = total === 0 ? 'flex' : 'none';
    if (total === 0) {
        stream.innerHTML = '';
        stream.appendChild(emptyMsg);
        renderedRows.clear();
        return;
    }

    // Auto-scroll: snap to bottom
    const atBottom = autoScroll && !isPaused;
    if (atBottom) scrollTop = Math.max(0, total * ROW_HEIGHT - stream.clientHeight);

    // Determine visible window
    const startRow  = Math.max(0, Math.floor(scrollTop / ROW_HEIGHT) - 5);
    const endRow    = Math.min(total - 1, startRow + RENDER_ROWS + 10);

    const topPad    = startRow * ROW_HEIGHT;
    const bottomPad = Math.max(0, (total - 1 - endRow) * ROW_HEIGHT);

    // Build fragment
    renderedRows.clear();
    const frag = document.createDocumentFragment();

    const topSpacer = document.createElement('div');
    topSpacer.className = 'virtual-spacer-top';
    topSpacer.style.height = topPad + 'px';
    frag.appendChild(topSpacer);

    for (let i = startRow; i <= endRow; i++) {
        const row = buildRow(filteredBuf[i], i);
        renderedRows.set(i, row);
        frag.appendChild(row);
    }

    const botSpacer = document.createElement('div');
    botSpacer.className = 'virtual-spacer-bottom';
    botSpacer.style.height = bottomPad + 'px';
    frag.appendChild(botSpacer);

    // Save and restore scroll position to prevent jump
    const savedScroll = stream.scrollTop;
    stream.innerHTML = '';
    stream.appendChild(frag);
    stream.appendChild(emptyMsg);

    if (atBottom) {
        stream.scrollTop = stream.scrollHeight;
    } else {
        stream.scrollTop = savedScroll;
    }
}

/* ═══════════════════════════════════════════════════════════
   ROW BUILDER
═══════════════════════════════════════════════════════════ */
function buildRow(entry, idx) {
    const lvl  = entry.level || 'INFO';
    const row  = document.createElement('div');
    row.className = 'log-row' + (expandedIdx === idx ? ' expanded' : '');
    row.dataset.idx = idx;

    // Gutter
    const gutter = document.createElement('div');
    gutter.className = `log-gutter gutter-${lvl}`;
    row.appendChild(gutter);

    // Main
    const main = document.createElement('div');
    main.className = 'log-main';

    // Level badge
    const badge = document.createElement('span');
    badge.className = `log-level-badge lvl-${lvl}`;
    badge.textContent = lvl;
    main.appendChild(badge);

    // Timestamp
    const ts = document.createElement('span');
    ts.className = 'log-ts';
    ts.textContent = fmtTs(entry.timestamp || '');
    ts.title = entry.timestamp || '';
    main.appendChild(ts);

    // Body
    const body = document.createElement('div');
    body.className = 'log-body';

    const msgLine = document.createElement('div');
    msgLine.className = 'log-message';
    msgLine.textContent = entry.message || `${entry.method || '-'} ${entry.path || '-'}`;
    body.appendChild(msgLine);

    // Meta chips
    const meta = buildMetaLine(entry);
    if (meta) body.appendChild(meta);

    main.appendChild(body);
    row.appendChild(main);

    // Expanded detail
    const detail = document.createElement('div');
    detail.className = 'log-detail';
    if (expandedIdx === idx) detail.appendChild(buildDetail(entry));
    row.appendChild(detail);

    // Click toggle — in-place, no full re-render
    row.addEventListener('click', () => {
        if (expandedIdx === idx) {
            // Collapse in place
            expandedIdx = null;
            row.classList.remove('expanded');
            detail.innerHTML = '';
        } else {
            // Collapse any previously expanded row still in DOM
            if (expandedIdx !== null) {
                const prevRow = renderedRows.get(expandedIdx);
                if (prevRow) {
                    prevRow.classList.remove('expanded');
                    const prevDetail = prevRow.querySelector('.log-detail');
                    if (prevDetail) prevDetail.innerHTML = '';
                }
            }
            // Expand this one in place
            expandedIdx = idx;
            row.classList.add('expanded');
            detail.appendChild(buildDetail(entry));
        }
    });

    return row;
}

function buildMetaLine(entry) {
    const chips = [];
    if (entry.logger_name && entry.logger_name !== '-') chips.push(['logger', entry.logger_name]);
    if (entry.status_code != null)                       chips.push(['status', entry.status_code]);
    if (entry.client_ip)                                 chips.push(['ip', entry.client_ip]);
    if (entry.process_time != null)                      chips.push(['ms', Math.round(entry.process_time * 1000)]);
    if (!chips.length) return null;

    const div = document.createElement('div');
    div.className = 'log-meta-line';
    chips.forEach(([k, v]) => {
        const chip = document.createElement('span');
        chip.className = 'meta-chip';
        chip.innerHTML = `<span class="key">${k}</span>${escHtml(String(v))}`;
        div.appendChild(chip);
    });
    return div;
}

/* ═══════════════════════════════════════════════════════════
   DETAIL BUILDER (expanded view)
═══════════════════════════════════════════════════════════ */
function buildDetail(entry) {
    const frag = document.createDocumentFragment();

    // Try to parse message as JSON (e.g. MongoDB driver logs)
    let parsed = null;
    if (typeof entry.message === 'string' && entry.message.trim().startsWith('{')) {
        try { parsed = JSON.parse(entry.message); } catch (_) {}
    }

    if (parsed && isMongoDriverLog(parsed)) {
        frag.appendChild(buildMongoCard(parsed));
    } else if (parsed) {
        frag.appendChild(buildJsonBlock(parsed));
    } else {
        // Show full message if it was truncated
        const full = document.createElement('div');
        full.style.cssText = 'font-size:12px;color:var(--text-secondary);line-height:1.7;padding:6px 0;word-break:break-all;';
        full.textContent = entry.message || '';
        frag.appendChild(full);
    }

    // Show all raw fields
    const extras = buildRawFields(entry);
    if (extras) frag.appendChild(extras);

    // Exception
    if (entry.exception) {
        const ex = document.createElement('pre');
        ex.className = 'exception-block';
        ex.textContent = entry.exception;
        frag.appendChild(ex);
    }

    return frag;
}

function isMongoDriverLog(obj) {
    return !!(obj.topologyId || obj.serverHost || obj.driverConnectionId != null);
}

function buildMongoCard(obj) {
    const card = document.createElement('div');
    card.className = 'mongo-card';

    // Header
    const header = document.createElement('div');
    header.className = 'mongo-card-header';

    const badge = document.createElement('span');
    badge.className = 'mongo-badge';
    badge.textContent = 'MONGODB';
    header.appendChild(badge);

    if (obj.serverHost) {
        const host = document.createElement('span');
        host.className = 'mongo-host';
        host.textContent = `${obj.serverHost}:${obj.serverPort || 27017}`;
        header.appendChild(host);
    }

    if (obj.awaited) {
        const aw = document.createElement('span');
        aw.style.cssText = 'font-size:10px;color:var(--text-muted);font-family:"DM Mono",monospace;';
        aw.textContent = 'awaited';
        header.appendChild(aw);
    }

    if (obj.durationMS != null) {
        const dur = document.createElement('span');
        const ms = Math.round(obj.durationMS);
        dur.className = `mongo-duration ${ms < 100 ? 'fast' : ms < 5000 ? 'slow' : 'vslow'}`;
        dur.textContent = `${ms.toLocaleString()} ms`;
        header.appendChild(dur);
    }

    card.appendChild(header);

    // Body — key fields
    const body = document.createElement('div');
    body.className = 'mongo-card-body';

    const fields = [
        ['Event', obj.message],
        ['Topology ID', obj.topologyId?.$oid],
        ['Connection ID', obj.serverConnectionId],
        ['Driver Conn', obj.driverConnectionId],
    ].filter(([,v]) => v != null);

    fields.forEach(([k, v]) => {
        const field = document.createElement('div');
        field.className = 'mongo-field';
        field.innerHTML = `<span class="mongo-field-key">${escHtml(k)}</span><span class="mongo-field-val">${escHtml(String(v))}</span>`;
        body.appendChild(field);
    });

    // Tags from reply if present
    if (obj.reply && typeof obj.reply === 'string') {
        try {
            const reply = JSON.parse(obj.reply);
            if (reply.tags) {
                const tagField = document.createElement('div');
                tagField.className = 'mongo-field';
                tagField.style.gridColumn = '1/-1';
                const tagPairs = Object.entries(reply.tags).map(([k,v])=>`${k}: ${v}`).join(' · ');
                tagField.innerHTML = `<span class="mongo-field-key">Tags</span><span class="mongo-field-val">${escHtml(tagPairs)}</span>`;
                body.appendChild(tagField);
            }
            if (reply.setName) {
                const setField = document.createElement('div');
                setField.className = 'mongo-field';
                setField.innerHTML = `<span class="mongo-field-key">Replica Set</span><span class="mongo-field-val">${escHtml(reply.setName)} (v${reply.setVersion||'?'}) — ${reply.secondary ? 'SECONDARY' : 'PRIMARY'}</span>`;
                body.appendChild(setField);
            }
        } catch (_) {}
    }

    card.appendChild(body);
    return card;
}

function buildJsonBlock(obj) {
    const pre = document.createElement('pre');
    pre.className = 'json-block';
    pre.textContent = JSON.stringify(obj, null, 2);
    return pre;
}

function buildRawFields(entry) {
    const skip = new Set(['message','level','timestamp','exception','logger_name']);
    const pairs = Object.entries(entry).filter(([k]) => !skip.has(k) && entry[k] != null && entry[k] !== '-');
    if (!pairs.length) return null;

    const wrap = document.createElement('div');
    wrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;';
    pairs.forEach(([k, v]) => {
        const chip = document.createElement('span');
        chip.style.cssText = 'font-family:"DM Mono",monospace;font-size:10px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:4px;padding:2px 7px;color:var(--text-muted);';
        chip.innerHTML = `<span style="color:rgba(165,180,252,0.6)">${escHtml(k)}</span> ${escHtml(String(v))}`;
        wrap.appendChild(chip);
    });
    return wrap;
}

/* ═══════════════════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════════════════ */
function fmtTs(ts) {
    if (!ts) return '-';
    try {
        const d = new Date(ts);
        const hh = String(d.getHours()).padStart(2,'0');
        const mm = String(d.getMinutes()).padStart(2,'0');
        const ss = String(d.getSeconds()).padStart(2,'0');
        return `${hh}:${mm}:${ss}`;
    } catch (_) { return ts.slice(11,19) || ts; }
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function refreshLoggerOptions() {
    const cur = loggerFilter.value;
    loggerFilter.innerHTML = '';
    Array.from(knownLoggers).sort().forEach(name => {
        const opt = document.createElement('option');
        opt.value = name; opt.textContent = name;
        loggerFilter.appendChild(opt);
    });
    loggerFilter.value = knownLoggers.has(cur) ? cur : 'ALL';
}

/* ═══════════════════════════════════════════════════════════
   PUSH LOG
═══════════════════════════════════════════════════════════ */
function pushLog(entry) {
    if (isPaused) return;

    const loggerName = entry.logger_name || '-';
    const isNew = !knownLoggers.has(loggerName);
    knownLoggers.add(loggerName);
    if (isNew) refreshLoggerOptions();

    logBuffer.push(entry);

    // Cap buffer — drop oldest
    if (logBuffer.length > MAX_BUFFER) {
        logBuffer.splice(0, logBuffer.length - MAX_BUFFER);
        overflowNotice.style.display = 'flex';
        capNoticeCount.textContent   = MAX_BUFFER;
    }

    applyFilter(); // also calls scheduleRender
}

/* ═══════════════════════════════════════════════════════════
   SCROLL HANDLING
═══════════════════════════════════════════════════════════ */
stream.addEventListener('scroll', () => {
    scrollTop = stream.scrollTop;
    const nearBottom = (stream.scrollHeight - stream.scrollTop - stream.clientHeight) < 60;
    autoScroll = nearBottom;
    scheduleRender();
}, { passive: true });

/* ═══════════════════════════════════════════════════════════
   CONTROLS
═══════════════════════════════════════════════════════════ */
pauseBtn.addEventListener('click', () => {
    isPaused = !isPaused;
    pauseBtn.textContent   = isPaused ? '▶ Resume' : '⏸ Pause';
    pauseBtn.style.background = isPaused ? 'rgba(34,211,160,0.1)' : '';
    pauseBtn.style.borderColor = isPaused ? 'rgba(34,211,160,0.3)' : '';
    pauseBtn.style.color       = isPaused ? '#6ee7b7' : '';
    liveInd.style.display   = isPaused ? 'none' : 'inline-flex';
    pausedInd.style.display = isPaused ? 'inline-flex' : 'none';
    if (!isPaused) { applyFilter(); autoScroll = true; }
});

clearBtn.addEventListener('click', () => {
    logBuffer = [];
    filteredBuf = [];
    expandedIdx = null;
    overflowNotice.style.display = 'none';
    updateStats();
    stream.innerHTML = '';
    stream.appendChild(emptyMsg);
    emptyMsg.style.display = 'flex';
});

levelFilter.addEventListener('change', applyFilter);
loggerFilter.addEventListener('change', applyFilter);
durFilter.addEventListener('change', applyFilter);
searchFilter.addEventListener('input', scheduleFilter);

/* ═══════════════════════════════════════════════════════════
   WEBSOCKET
═══════════════════════════════════════════════════════════ */
function setWsStatus(text, color) {
    wsStatus.textContent = text;
    wsStatus.style.color = color;
}

const proto  = location.protocol === 'https:' ? 'wss:' : 'ws:';
const socket = new WebSocket(`${proto}//${location.host}/ws/logs`);

socket.onopen = () => {
    setWsStatus('● Connected', 'var(--success)');
    pushLog({ timestamp: new Date().toISOString(), level: 'INFO', logger_name: 'ws.client', message: 'WebSocket connected to /ws/logs', method: 'WS', path: '/ws/logs', status_code: 101, client_ip: 'local', process_time: 0 });
};

socket.onmessage = (e) => {
    try { pushLog(JSON.parse(e.data)); } catch (_) {}
};

socket.onclose = () => {
    setWsStatus('● Disconnected', 'var(--danger)');
    pushLog({ timestamp: new Date().toISOString(), level: 'WARNING', logger_name: 'ws.client', message: 'WebSocket disconnected', method: 'WS', path: '/ws/logs', status_code: '-', client_ip: 'local', process_time: 0 });
};

socket.onerror = () => setWsStatus('● Error', 'var(--danger)');
</script>
{% endblock %}