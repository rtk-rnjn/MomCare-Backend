{% extends "base.html.jinja" %}

{% block title %}Data Explorer{% endblock %}
{% block page_title %}Data Explorer{% endblock %}

{% block head %}
<style>
    /* ── LAYOUT ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
        margin-bottom: 22px;
    }

    .stat-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 20px;
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s ease;
    }

    .stat-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 15% 15%, rgba(99, 102, 241, 0.1), transparent 55%);
        pointer-events: none;
    }

    .stat-card:hover {
        border-color: var(--border-accent);
    }

    .stat-label {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 32px;
        font-weight: 800;
        margin-top: 6px;
        letter-spacing: -0.02em;
        color: var(--text-primary);
    }

    .stat-hint {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 8px;
        font-family: 'DM Mono', monospace;
    }

    /* ── PANEL ── */
    .panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .panel-header {
        padding: 18px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: linear-gradient(to right, rgba(99,102,241,0.04), transparent);
    }

    .panel-title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: -0.01em;
    }

    .panel-subtitle {
        color: var(--text-muted);
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        margin-top: 3px;
    }

    .panel-body {
        padding: 20px;
    }

    /* ── CONTROLS ── */
    .controls-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .control {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .label {
        font-family: 'DM Mono', monospace;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 11px;
    }

    .input, .select {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        border-radius: 8px;
        padding: 9px 12px;
        outline: none;
        font-size: 13px;
        transition: all 0.15s ease;
    }

    .input:focus, .select:focus, textarea.input:focus {
        border-color: var(--border-accent);
        color: var(--text-primary);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    textarea.input {
        resize: vertical;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
    }

    /* ── BUTTONS ── */
    .btn-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .btn {
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        color: var(--text-secondary);
        border-radius: 8px;
        padding: 8px 14px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.15s ease;
        letter-spacing: 0.03em;
    }

    .btn:hover {
        color: var(--text-primary);
        border-color: var(--border-accent);
        background: var(--bg-hover);
    }

    .btn-sm { padding: 5px 10px; font-size: 11px; }

    .btn-primary {
        background: rgba(99, 102, 241, 0.18);
        border-color: rgba(99, 102, 241, 0.5);
        color: #c7d2fe;
    }

    .btn-primary:hover {
        background: rgba(99, 102, 241, 0.28);
        border-color: rgba(99, 102, 241, 0.8);
        color: #e0e7ff;
    }

    .btn-danger {
        background: rgba(244, 63, 94, 0.1);
        border-color: rgba(244, 63, 94, 0.35);
        color: #fda4af;
    }

    .btn-danger:hover {
        background: rgba(244, 63, 94, 0.2);
        border-color: rgba(244, 63, 94, 0.6);
    }

    /* ── SPLIT LAYOUT ── */
    .split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 4px;
    }

    @media (max-width: 1100px) { .split { grid-template-columns: 1fr; } }

    /* ── KEYS TABLE ── */
    .keys-table-wrap {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    th, td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--border);
        text-align: left;
    }

    th {
        font-family: 'DM Mono', monospace;
        letter-spacing: 0.07em;
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 11px;
        background: var(--bg-elevated);
    }

    tbody tr:last-child td { border-bottom: none; }

    tbody tr:hover { background: var(--bg-hover); }

    .mono {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
    }

    /* ── TYPE BADGE ── */
    .type-badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        font-weight: 500;
        border: 1px solid;
    }

    .type-hash   { background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.35); color: #c7d2fe; }
    .type-string { background: rgba(34,211,160,0.1);  border-color: rgba(34,211,160,0.3);  color: #6ee7b7; }
    .type-list   { background: rgba(245,158,11,0.1);  border-color: rgba(245,158,11,0.3);  color: #fcd34d; }
    .type-set    { background: rgba(244,63,94,0.1);   border-color: rgba(244,63,94,0.3);   color: #fda4af; }
    .type-zset   { background: rgba(139,92,246,0.12); border-color: rgba(139,92,246,0.35); color: #c4b5fd; }

    /* ── TTL BADGE ── */
    .ttl-badge {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        padding: 2px 7px;
        border-radius: 4px;
    }

    .ttl-ok      { background: rgba(34,211,160,0.1);  color: #6ee7b7; }
    .ttl-warn    { background: rgba(245,158,11,0.1);  color: #fcd34d; }
    .ttl-persist { background: rgba(120,120,141,0.15); color: var(--text-muted); }

    /* ── KEY INSPECTOR ── */
    .inspector-wrap {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 10px;
    }

    .inspector-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .inspector-key-label {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ── KEY VALUE DISPLAY ── */
    .key-detail-panel {
        background: #0b0b12;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        flex: 1;
    }

    .key-meta-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-elevated);
        flex-wrap: wrap;
    }

    .key-meta-item {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .key-meta-label { color: var(--text-muted); }
    .key-meta-value { color: var(--text-secondary); }

    .hash-table-wrap {
        overflow: auto;
        max-height: 380px;
    }

    .hash-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .hash-table th {
        position: sticky;
        top: 0;
        background: #0e0e18;
        z-index: 1;
        padding: 8px 12px;
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        text-transform: uppercase;
        border-bottom: 1px solid var(--border);
    }

    .hash-table td {
        padding: 8px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        vertical-align: top;
    }

    .hash-table tr:last-child td { border-bottom: none; }

    .hash-field {
        font-family: 'DM Mono', monospace;
        color: #a5b4fc;
        word-break: break-all;
        max-width: 260px;
    }

    .hash-value {
        font-family: 'DM Mono', monospace;
        color: var(--text-secondary);
        word-break: break-all;
    }

    .hash-field-parts {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .field-segment {
        display: inline-block;
        padding: 1px 5px;
        border-radius: 3px;
        font-size: 11px;
    }

    .field-method  { background: rgba(99,102,241,0.15); color: #c7d2fe; }
    .field-path    { color: var(--text-secondary); }
    .field-status-200 { background: rgba(34,211,160,0.12); color: #6ee7b7; }
    .field-status-4xx { background: rgba(245,158,11,0.12); color: #fcd34d; }
    .field-status-5xx { background: rgba(244,63,94,0.12);  color: #fda4af; }

    pre.codebox {
        background: #0b0b12;
        border-radius: 0;
        padding: 14px;
        color: var(--text-secondary);
        overflow: auto;
        max-height: 380px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        line-height: 1.7;
        margin: 0;
    }

    .placeholder-msg {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 200px;
        flex-direction: column;
        gap: 10px;
        color: var(--text-muted);
        font-family: 'DM Mono', monospace;
        font-size: 13px;
    }

    .placeholder-icon {
        font-size: 28px;
        opacity: 0.3;
    }

    /* ── STATUS LINE ── */
    .status-line {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 6px;
        min-height: 18px;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-dot.ok    { background: var(--success); box-shadow: 0 0 6px var(--success); }
    .status-dot.error { background: var(--danger);  box-shadow: 0 0 6px var(--danger); }

    /* ── PILL / BADGE ── */
    .pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        font-size: 12px;
        font-family: 'DM Mono', monospace;
    }

    .pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--success);
        box-shadow: 0 0 6px var(--success);
    }

    /* ── MONGO DOC ── */
    .mongo-doc-card {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--bg-elevated);
        overflow: hidden;
        margin-bottom: 10px;
        transition: border-color 0.15s ease;
    }

    .mongo-doc-card:hover { border-color: var(--border-accent); }

    .mongo-doc-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
        background: rgba(99,102,241,0.04);
    }

    .mongo-doc-id {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: #a5b4fc;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 220px;
    }

    .mongo-doc-body {
        max-height: 180px;
        overflow: auto;
        padding: 10px 12px;
    }

    /* ── MONGO STATS ── */
    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        padding: 14px;
    }

    .stats-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .stats-item-label {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .stats-item-value {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.01em;
    }

    .stats-item-sub {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
    }

    .stats-bar-wrap {
        padding: 0 14px 14px;
    }

    .stats-bar-label {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 5px;
        display: flex;
        justify-content: space-between;
    }

    .stats-bar {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
    }

    .stats-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #6366f1, #818cf8);
        border-radius: 2px;
        transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
    }

    .stats-ns {
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--text-muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .stats-ns span { color: #a5b4fc; }

    .panel-right-header {
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-secondary);
        margin-bottom: 10px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
    }

    .separator {
        height: 1px;
        background: var(--border);
        margin: 14px 0;
    }
</style>
{% endblock %}

{% block content %}

<!-- STAT CARDS -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Redis Keys</div>
        <div class="stat-value">{{ redis_info.dbsize or 0 }}</div>
        <div class="stat-hint">
            Clients: {{ redis_info.connected_clients or 0 }} &nbsp;·&nbsp; Mem: {{ redis_info.used_memory_human }}
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-label">MongoDB Collections</div>
        <div class="stat-value">{{ mongo_collections|length }}</div>
        <div class="stat-hint">Ready for browsing</div>
    </div>
</div>

<!-- REDIS PANEL -->
<div class="panel">
    <div class="panel-header">
        <div>
            <div class="panel-title">Redis Explorer</div>
            <div class="panel-subtitle">Scan keys · Inspect values · Manage TTLs</div>
        </div>
        <div class="pill">
            <span class="pill-dot" style="{{ '' if redis_info.available else 'background:var(--danger);box-shadow:0 0 6px var(--danger)' }}"></span>
            {{ 'Online' if redis_info.available else 'Offline' }}
        </div>
    </div>
    <div class="panel-body">
        <div class="controls-grid">
            <div class="control">
                <label class="label">Pattern</label>
                <input id="redisPattern" class="input" value="*" placeholder="session:* or metrics:*" />
            </div>
            <div class="control">
                <label class="label">Scan count</label>
                <input id="redisCount" class="input" type="number" min="1" max="200" value="50" />
            </div>
            <div class="control">
                <label class="label">Actions</label>
                <div class="btn-row">
                    <button class="btn btn-primary" onclick="loadRedisKeys(true)">↺ Scan</button>
                    <button class="btn" onclick="loadRedisKeys(false)">Next →</button>
                </div>
            </div>
        </div>

        <div class="split">
            <!-- Keys list -->
            <div>
                <div class="keys-table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Type</th>
                                <th>TTL</th>
                                <th>Size</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="redisKeysBody">
                            <tr>
                                <td colspan="5" class="mono" style="color:var(--text-muted);padding:20px 12px;">
                                    Click <strong style="color:var(--text-secondary)">Scan</strong> to load keys
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="redisStatus" class="status-line"></div>
            </div>

            <!-- Key inspector -->
            <div class="inspector-wrap">
                <div class="inspector-toolbar">
                    <span class="inspector-key-label" id="selectedKeyLabel">No key selected</span>
                    <button class="btn btn-sm" onclick="refreshSelectedKey()">↺ Refresh</button>
                    <button class="btn btn-sm btn-danger" onclick="deleteSelectedKey()">✕ Delete</button>
                </div>
                <div class="key-detail-panel" id="keyDetailPanel">
                    <div class="placeholder-msg">
                        <span class="placeholder-icon">⌨</span>
                        Select a key to inspect
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MONGODB PANEL -->
<div class="panel">
    <div class="panel-header">
        <div>
            <div class="panel-title">MongoDB Explorer</div>
            <div class="panel-subtitle">Browse collections · Filter documents · View stats</div>
        </div>
        <div class="btn-row">
            <button class="btn" onclick="loadCollectionStats()">↺ Stats</button>
        </div>
    </div>
    <div class="panel-body">
        <div class="controls-grid">
            <div class="control">
                <label class="label">Collection</label>
                <select id="collectionSelect" class="select">
                    {% for name in mongo_collections %}
                    <option value="{{ name }}">{{ name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="control">
                <label class="label">Page size</label>
                <input id="pageSizeInput" class="input" type="number" value="20" min="1" max="100" />
            </div>
            <div class="control">
                <label class="label">Sort field / dir</label>
                <div class="btn-row">
                    <input id="sortFieldInput" class="input" value="_id" style="flex:1;" />
                    <select id="sortDirInput" class="select" style="width:80px;">
                        <option value="-1">Desc</option>
                        <option value="1">Asc</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="controls-grid">
            <div class="control">
                <label class="label">Filter (JSON)</label>
                <textarea id="filterInput" class="input" rows="3" placeholder='{"user_id": "..."}'></textarea>
            </div>
        </div>
        <div class="btn-row" style="margin-bottom:16px;">
            <button class="btn btn-primary" onclick="loadMongoDocs(true)">▶ Run Query</button>
            <button class="btn" onclick="loadMongoDocs(false)">Next Page →</button>
        </div>

        <div class="split">
            <!-- Documents -->
            <div>
                <div id="mongoDocsBody">
                    <div class="placeholder-msg" style="border:1px solid var(--border);border-radius:10px;min-height:160px;">
                        <span class="placeholder-icon">⊡</span>
                        Run a query to load documents
                    </div>
                </div>
                <div id="mongoStatus" class="status-line"></div>
            </div>

            <!-- Stats -->
            <div>
                <div class="panel-right-header">Collection Stats</div>
                <div id="mongoStatsDisplay" style="border:1px solid var(--border);border-radius:10px;overflow:hidden;background:var(--bg-elevated);">
                    <div class="placeholder-msg" style="min-height:160px;">
                        <span class="placeholder-icon">◫</span>
                        No stats loaded
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
    const redisState = { cursor: 0, selectedKey: null };

    /* ─── STATUS LINE ─── */
    function setStatus(elId, text, ok = true) {
        const el = document.getElementById(elId);
        if (!el) return;
        el.innerHTML = `<span class="status-dot ${ok ? 'ok' : 'error'}"></span>${text}`;
    }

    /* ─── REDIS: SCAN ─── */
    async function loadRedisKeys(resetCursor) {
        if (resetCursor) redisState.cursor = 0;
        const pattern = document.getElementById('redisPattern').value || '*';
        const count = Math.min(200, Math.max(1, parseInt(document.getElementById('redisCount').value || '50', 10)));
        setStatus('redisStatus', 'Scanning…', true);
        try {
            const res = await fetch(`/admin/datastores/api/redis/scan?pattern=${encodeURIComponent(pattern)}&count=${count}&cursor=${redisState.cursor}`);
            const data = await res.json();
            redisState.cursor = data.cursor;
            renderRedisKeys(data.keys || []);
            setStatus('redisStatus', data.has_more ? `Cursor ${data.cursor} · more available` : `Scan complete · ${(data.keys||[]).length} keys`, true);
        } catch (e) {
            setStatus('redisStatus', 'Failed to scan keys', false);
        }
    }

    function typeBadge(type) {
        return `<span class="type-badge type-${type}">${type}</span>`;
    }

    function ttlBadge(ttl) {
        if (ttl === -1) return `<span class="ttl-badge ttl-persist">∞</span>`;
        const cls = ttl < 300 ? 'ttl-warn' : 'ttl-ok';
        return `<span class="ttl-badge ${cls}">${ttl}s</span>`;
    }

    function renderRedisKeys(keys) {
        const body = document.getElementById('redisKeysBody');
        if (!keys.length) {
            body.innerHTML = '<tr><td colspan="5" class="mono" style="padding:20px 12px;color:var(--text-muted)">No keys matched the pattern</td></tr>';
            return;
        }
        body.innerHTML = keys.map(item => `
            <tr>
                <td class="mono" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-secondary);" title="${item.key}">${item.key}</td>
                <td>${typeBadge(item.type)}</td>
                <td>${ttlBadge(item.ttl)}</td>
                <td class="mono" style="color:var(--text-muted)">${item.approx_length ?? '—'}</td>
                <td><button class="btn btn-sm" onclick="inspectRedisKey('${item.key.replace(/'/g,"\\'")}')">Inspect</button></td>
            </tr>
        `).join('');
    }

    /* ─── REDIS: INSPECT KEY ─── */
    async function inspectRedisKey(key) {
        const panel = document.getElementById('keyDetailPanel');
        const label = document.getElementById('selectedKeyLabel');
        label.textContent = key;
        redisState.selectedKey = key;
        panel.innerHTML = `<div class="placeholder-msg"><span class="placeholder-icon" style="animation:spin 1s linear infinite">↻</span>Loading…</div>`;
        try {
            const res = await fetch(`/admin/datastores/api/redis/key/${encodeURIComponent(key)}?max_items=120`);
            const data = await res.json();
            renderKeyDetail(panel, data);
        } catch (e) {
            panel.innerHTML = `<div class="placeholder-msg"><span style="color:var(--danger)">✕</span>Unable to load key</div>`;
        }
    }

    function renderKeyDetail(panel, data) {
        const type = data.type || 'string';
        const ttl  = data.ttl;
        const metaBar = `
            <div class="key-meta-bar">
                <span class="key-meta-item">${typeBadge(type)}</span>
                <span class="key-meta-item"><span class="key-meta-label">TTL&nbsp;</span><span class="key-meta-value">${ttlBadge(ttl)}</span></span>
                ${data.size ? `<span class="key-meta-item"><span class="key-meta-label">Size&nbsp;</span><span class="key-meta-value">${data.size}</span></span>` : ''}
            </div>`;

        if (type === 'hash' && data.value && typeof data.value === 'object') {
            const entries = Object.entries(data.value);
            const rows = entries.map(([field, val]) => {
                const fieldHtml = renderHashField(field);
                return `<tr>
                    <td class="hash-field">${fieldHtml}</td>
                    <td class="hash-value">${escHtml(String(val))}</td>
                </tr>`;
            }).join('');
            panel.innerHTML = metaBar + `
                <div class="hash-table-wrap">
                    <table class="hash-table">
                        <thead><tr><th>Field</th><th>Value</th></tr></thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>`;
        } else {
            const pretty = JSON.stringify(data.value ?? data, null, 2);
            panel.innerHTML = metaBar + `<pre class="codebox">${escHtml(pretty)}</pre>`;
        }
    }

    /* Parse endpoint-style hash fields like: METHOD /path|STATUS */
    function renderHashField(field) {
        const match = field.match(/^(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\s+(.+)\|(\d{3})$/);
        if (!match) return `<span style="word-break:break-all">${escHtml(field)}</span>`;
        const [, method, path, status] = match;
        const statusCls = status.startsWith('2') ? 'field-status-200'
                        : status.startsWith('4') ? 'field-status-4xx'
                        : 'field-status-5xx';
        return `<div class="hash-field-parts">
            <span>
                <span class="field-segment field-method">${method}</span>
                <span class="field-segment field-path">${escHtml(path)}</span>
            </span>
            <span class="field-segment ${statusCls}" style="align-self:flex-start;">${status}</span>
        </div>`;
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    async function refreshSelectedKey() {
        if (!redisState.selectedKey) return;
        await inspectRedisKey(redisState.selectedKey);
    }

    async function deleteSelectedKey() {
        if (!redisState.selectedKey) return;
        if (!confirm(`Delete key "${redisState.selectedKey}"?`)) return;
        try {
            await fetch(`/admin/datastores/api/redis/key/${encodeURIComponent(redisState.selectedKey)}`, { method: 'DELETE' });
            redisState.selectedKey = null;
            document.getElementById('selectedKeyLabel').textContent = 'No key selected';
            document.getElementById('keyDetailPanel').innerHTML = `<div class="placeholder-msg"><span style="color:var(--success)">✓</span>Key deleted</div>`;
            loadRedisKeys(true);
        } catch (e) {
            document.getElementById('keyDetailPanel').innerHTML = `<div class="placeholder-msg"><span style="color:var(--danger)">✕</span>Delete failed</div>`;
        }
    }

    /* ─── MONGO: DOCS ─── */
    const mongoState = { page: 1 };

    async function loadMongoDocs(resetPage) {
        if (resetPage) mongoState.page = 1; else mongoState.page += 1;
        const collection = document.getElementById('collectionSelect').value;
        const filter = document.getElementById('filterInput').value.trim();
        const pageSize = Math.min(100, Math.max(1, parseInt(document.getElementById('pageSizeInput').value || '20', 10)));
        const sortField = document.getElementById('sortFieldInput').value || '_id';
        const sortDir = parseInt(document.getElementById('sortDirInput').value || '-1', 10);
        setStatus('mongoStatus', 'Loading…', true);
        const params = new URLSearchParams({ page: mongoState.page, page_size: pageSize, sort_field: sortField, sort_dir: sortDir });
        if (filter) params.append('filter', filter);
        try {
            const res = await fetch(`/admin/datastores/api/mongo/collection/${encodeURIComponent(collection)}?${params}`);
            const data = await res.json();
            renderMongoDocs(data.items || []);
            setStatus('mongoStatus', `Page ${data.page} / ${data.total_pages} · ${data.total} total docs`, true);
        } catch (e) {
            setStatus('mongoStatus', 'Query failed', false);
        }
    }

    function renderMongoDocs(items) {
        const body = document.getElementById('mongoDocsBody');
        if (!items.length) {
            body.innerHTML = `<div class="placeholder-msg" style="border:1px solid var(--border);border-radius:10px;min-height:100px;"><span class="placeholder-icon">⊡</span>No documents matched</div>`;
            return;
        }
        body.innerHTML = items.map(doc => {
            const id = doc._id?.$oid || doc._id || '—';
            const pretty = JSON.stringify(doc, null, 2);
            return `<div class="mongo-doc-card">
                <div class="mongo-doc-header">
                    <span class="mongo-doc-id" title="${escHtml(String(id))}">${escHtml(String(id))}</span>
                    <button class="btn btn-sm" onclick="copyDoc(${JSON.stringify(pretty)})">Copy</button>
                </div>
                <div class="mongo-doc-body">
                    <pre style="font-family:'DM Mono',monospace;font-size:11px;color:var(--text-secondary);line-height:1.7;margin:0;">${escHtml(pretty)}</pre>
                </div>
            </div>`;
        }).join('');
    }

    function copyDoc(text) {
        navigator.clipboard.writeText(text).catch(() => {});
    }

    /* ─── MONGO: STATS ─── */
    async function loadCollectionStats() {
        const collection = document.getElementById('collectionSelect').value;
        const display = document.getElementById('mongoStatsDisplay');
        display.innerHTML = `<div class="placeholder-msg" style="min-height:120px;"><span class="placeholder-icon">↻</span>Loading…</div>`;
        try {
            const res = await fetch(`/admin/datastores/api/mongo/collection/${encodeURIComponent(collection)}/stats`);
            const data = await res.json();
            renderMongoStats(display, data);
        } catch (e) {
            display.innerHTML = `<div class="placeholder-msg" style="min-height:120px;"><span style="color:var(--danger)">✕</span>Unable to fetch stats</div>`;
        }
    }

    function fmtBytes(b) {
        if (!b) return '0 B';
        const units = ['B','KB','MB','GB'];
        let i = 0;
        while (b >= 1024 && i < units.length-1) { b /= 1024; i++; }
        return `${b.toFixed(1)} ${units[i]}`;
    }

    function fmtNum(n) {
        return Number(n||0).toLocaleString();
    }

    function renderMongoStats(el, data) {
        const s = data.stats || {};
        const ns = s.ns || data.collection || '—';
        const ratio = s.storageSize ? Math.min(100, Math.round((s.size / s.storageSize) * 100)) : 0;

        el.innerHTML = `
            <div class="stats-ns">ns: <span>${escHtml(ns)}</span></div>
            <div class="stats-grid">
                <div class="stats-item">
                    <div class="stats-item-label">Documents</div>
                    <div class="stats-item-value">${fmtNum(s.count)}</div>
                </div>
                <div class="stats-item">
                    <div class="stats-item-label">Avg Doc Size</div>
                    <div class="stats-item-value">${fmtBytes(s.avgObjSize)}</div>
                </div>
                <div class="stats-item">
                    <div class="stats-item-label">Data Size</div>
                    <div class="stats-item-value">${fmtBytes(s.size)}</div>
                </div>
                <div class="stats-item">
                    <div class="stats-item-label">Storage Size</div>
                    <div class="stats-item-value">${fmtBytes(s.storageSize)}</div>
                </div>
                <div class="stats-item">
                    <div class="stats-item-label">Indexes</div>
                    <div class="stats-item-value">${fmtNum(s.nindexes)}</div>
                    <div class="stats-item-sub">${fmtBytes(s.totalIndexSize)} total</div>
                </div>
            </div>
            <div class="stats-bar-wrap">
                <div class="stats-bar-label">
                    <span>Data fill ratio</span>
                    <span>${ratio}%</span>
                </div>
                <div class="stats-bar">
                    <div class="stats-bar-fill" id="statsBarFill" style="width:0%"></div>
                </div>
            </div>`;

        // Animate bar
        requestAnimationFrame(() => {
            const fill = document.getElementById('statsBarFill');
            if (fill) fill.style.width = ratio + '%';
        });
    }

    /* ─── INIT ─── */
    document.addEventListener('DOMContentLoaded', () => {
        const sel = document.getElementById('collectionSelect');
        if (sel && sel.value) {
            loadMongoDocs(true);
            loadCollectionStats();
        }
        loadRedisKeys(true);

        // Re-load stats when collection changes
        sel && sel.addEventListener('change', () => {
            loadMongoDocs(true);
            loadCollectionStats();
        });
    });

    /* Spin animation for loader */
    const style = document.createElement('style');
    style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
    document.head.appendChild(style);
</script>
{% endblock %}