{% extends "base.html.jinja" %}

{% block title %}Data Manager{% endblock %}
{% block page_title %}Data Manager{% endblock %}

{% block head %}
<style>
    /* ── TOOLBAR PANEL ── */
    .toolbar-panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        animation: fadeInUp 0.3s ease both;
    }

    .toolbar-row {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 12px;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field-label {
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .field-select, .field-input {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-secondary);
        padding: 8px 12px;
        font-size: 13px;
        font-family: 'Instrument Sans', sans-serif;
        outline: none;
        transition: border-color 0.15s ease, color 0.15s ease;
        min-width: 160px;
    }

    .field-select:focus, .field-input:focus {
        border-color: var(--border-accent);
        color: var(--text-primary);
    }

    .field-input::placeholder { color: var(--text-muted); }

    /* ── BUTTONS ── */
    .btn {
        padding: 8px 16px;
        border-radius: 7px;
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        cursor: pointer;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        letter-spacing: 0.02em;
    }

    .btn-ghost {
        border: 1px solid var(--border);
        color: var(--text-secondary);
        background: var(--bg-elevated);
    }

    .btn-ghost:hover {
        border-color: var(--border-accent);
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    .btn-primary {
        border: 1px solid var(--accent);
        color: #fff;
        background: var(--accent);
    }

    .btn-primary:hover { background: #5254e7; border-color: #5254e7; }

    .btn-success {
        border: 1px solid #22d3a0;
        color: #fff;
        background: rgba(34,211,160,0.85);
    }

    .btn-success:hover { background: rgba(34,211,160,1); }

    .btn-danger {
        border: 1px solid rgba(244,63,94,0.4);
        color: #f43f5e;
        background: rgba(244,63,94,0.1);
    }

    .btn-danger:hover { background: rgba(244,63,94,0.2); }

    .btn-sm { 
        padding: 5px 12px; 
        font-size: 11px;
    }

    /* ── STATUS TEXT ── */
    #statusText {
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    #statusText::before {
        content: '●';
        font-size: 8px;
        color: var(--success);
    }

    #statusText.error::before { color: var(--danger); }

    /* ── TABLE PANEL ── */
    .panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        animation: fadeInUp 0.4s ease both;
        margin-bottom: 20px;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .data-table thead tr { background: var(--bg-elevated); }

    .data-table th {
        padding: 11px 14px;
        text-align: left;
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
        white-space: nowrap;
    }

    .data-table tbody tr {
        border-top: 1px solid var(--border);
        transition: background 0.12s ease;
    }

    .data-table tbody tr:hover { background: var(--bg-hover); }

    .data-table td {
        padding: 12px 14px;
        color: var(--text-secondary);
        vertical-align: top;
    }

    .mono {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
    }

    .record-pre {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--text-muted);
        white-space: pre-wrap;
        word-break: break-all;
        max-height: 160px;
        overflow-y: auto;
        line-height: 1.6;
    }

    .record-pre::-webkit-scrollbar { width: 3px; }
    .record-pre::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    .empty-row td {
        padding: 40px;
        text-align: center;
        color: var(--text-muted);
        font-style: italic;
        font-size: 13px;
    }

    /* ── SHORTCUTS PANEL ── */
    .shortcuts-panel {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        animation: fadeInUp 0.5s ease both;
        margin-bottom: 20px;
    }

    .shortcuts-title {
        font-family: 'Syne', sans-serif;
        font-weight: 600;
        font-size: 13px;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    #shortcutHint {
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        margin-bottom: 16px;
    }

    .shortcuts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

    @media (max-width: 640px) { .shortcuts-grid { grid-template-columns: 1fr; } }

    .shortcut-inputs {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
    }

    .shortcut-inputs .field-input { min-width: 200px; flex: 1; }

    .shortcuts-btns {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* ── PAGINATION ── */
    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        animation: fadeInUp 0.5s ease both;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

    #paginationInfo {
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
    }

    .page-btns { display: flex; gap: 6px; }

    /* ── MODAL ── */
    #editorModal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        z-index: 50;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    #editorModal.flex { display: flex; }

    .modal-box {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        width: 100%;
        max-width: 760px;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: modalIn 0.2s cubic-bezier(0.34,1.56,0.64,1) both;
        box-shadow: 0 24px 80px rgba(0,0,0,0.6);
    }

    @keyframes modalIn {
        from { opacity: 0; transform: scale(0.95) translateY(8px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        gap: 12px;
    }

    #modalTitle {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 15px;
        color: var(--text-primary);
    }

    .modal-mode-btns {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .modal-hint {
        padding: 10px 20px;
        font-size: 11px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
    }

    .modal-body::-webkit-scrollbar { width: 4px; }
    .modal-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* Field mode inputs */
    #fieldModePanel .field-group-row {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 12px;
    }

    #fieldModePanel label.field-label-main {
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    #fieldModePanel input[type="text"],
    #fieldModePanel input[type="number"],
    #fieldModePanel input[type="email"],
    #fieldModePanel select,
    #fieldModePanel textarea {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 7px;
        color: var(--text-secondary);
        padding: 8px 12px;
        font-size: 13px;
        font-family: 'Instrument Sans', sans-serif;
        outline: none;
        width: 100%;
        transition: border-color 0.15s ease;
    }

    #fieldModePanel input:focus,
    #fieldModePanel select:focus,
    #fieldModePanel textarea:focus {
        border-color: var(--border-accent);
        color: var(--text-primary);
    }

    #fieldModePanel input[readonly],
    #fieldModePanel select[readonly],
    #fieldModePanel textarea[readonly] {
        opacity: 0.4;
        cursor: not-allowed;
    }

    #fieldModePanel label.checkbox-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: var(--text-secondary);
        cursor: pointer;
        padding: 6px 0;
    }

    #fieldModePanel input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--accent);
        cursor: pointer;
    }

    #fieldModePanel textarea {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        resize: vertical;
    }

    #modalJson {
        width: 100%;
        height: 360px;
        padding: 14px;
        background: #07070e;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--text-secondary);
        outline: none;
        resize: vertical;
        line-height: 1.6;
    }

    #modalJson:focus { border-color: var(--border-accent); }

    .modal-footer {
        padding: 14px 20px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-shrink: 0;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}

{% block content %}

<!-- ── TOOLBAR ── -->
<div class="toolbar-panel">
    <div class="toolbar-row">
        <div class="field-group">
            <label class="field-label" for="collectionSelect">Collection</label>
            <select id="collectionSelect" class="field-select"></select>
        </div>

        <div class="field-group">
            <label class="field-label" for="pageSizeSelect">Page Size</label>
            <select id="pageSizeSelect" class="field-select" style="min-width:100px;">
                <option value="10">10</option>
                <option value="20" selected>20</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <button id="refreshBtn" class="btn btn-ghost">↻ Refresh</button>
        <button id="createBtn" class="btn btn-primary">+ Create</button>
    </div>

    <p id="statusText">Ready</p>
</div>

<!-- ── RECORDS TABLE ── -->
<div class="panel">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:220px;">ID</th>
                    <th>Document</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody id="recordsBody">
                <tr class="empty-row"><td colspan="3">No records loaded</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── PAGINATION ── -->
<div class="pagination">
    <div id="paginationInfo">Page 1 of 1</div>
    <div class="page-btns">
        <button id="prevBtn" class="btn btn-ghost btn-sm">← Prev</button>
        <button id="nextBtn" class="btn btn-ghost btn-sm">Next →</button>
    </div>
</div>

<!-- ── SHORTCUTS PANEL ── -->
<div class="shortcuts-panel">
    <p class="shortcuts-title">Collection Shortcuts</p>
    <p id="shortcutHint">Select a collection to see available shortcuts.</p>

    <div class="shortcut-inputs">
        <input id="quickUserId" type="text" placeholder="Credential / User ID" class="field-input" />
        <input id="quickEmail"  type="email" placeholder="New email address" class="field-input" />
    </div>

    <div class="shortcuts-btns">
        <button id="lockUserBtn"        class="btn btn-ghost btn-sm hidden">🔒 Lock User</button>
        <button id="unlockUserBtn"      class="btn btn-ghost btn-sm hidden">🔓 Unlock User</button>
        <button id="verifyEmailBtn"     class="btn btn-ghost btn-sm hidden">✓ Verify Email</button>
        <button id="unverifyEmailBtn"   class="btn btn-ghost btn-sm hidden">✗ Unverify Email</button>
        <button id="changeEmailBtn"     class="btn btn-ghost btn-sm hidden">✉ Change Email</button>
        <button id="resetAttemptsBtn"   class="btn btn-ghost btn-sm hidden">↺ Reset Login Attempts</button>
        <button id="regenPlanBtn"       class="btn btn-success btn-sm hidden">⚡ Regenerate Plan</button>
        <button id="deleteTodayPlanBtn" class="btn btn-danger btn-sm hidden">✕ Delete Today's Plan</button>
    </div>
</div>

<!-- ── EDITOR MODAL ── -->
<div id="editorModal">
    <div class="modal-box">

        <div class="modal-header">
            <h3 id="modalTitle">Edit Document</h3>
            <div class="modal-mode-btns">
                <button id="switchFieldModeBtn" class="btn btn-ghost btn-sm">⊞ Fields</button>
                <button id="switchJsonModeBtn"  class="btn btn-ghost btn-sm">{ } JSON</button>
                <button id="closeModalBtn"      class="btn btn-ghost btn-sm">✕</button>
            </div>
        </div>

        <div class="modal-hint">
            Field mode is preferred. Switch to JSON for advanced / nested edits.
        </div>

        <div class="modal-body">
            <div id="fieldModePanel"></div>
            <textarea id="modalJson" class="hidden" spellcheck="false"></textarea>
        </div>

        <div class="modal-footer">
            <button id="saveModalBtn" class="btn btn-primary">Save Changes</button>
        </div>

    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
    const collectionSelect  = document.getElementById('collectionSelect');
    const pageSizeSelect    = document.getElementById('pageSizeSelect');
    const refreshBtn        = document.getElementById('refreshBtn');
    const createBtn         = document.getElementById('createBtn');
    const recordsBody       = document.getElementById('recordsBody');
    const statusText        = document.getElementById('statusText');
    const prevBtn           = document.getElementById('prevBtn');
    const nextBtn           = document.getElementById('nextBtn');
    const paginationInfo    = document.getElementById('paginationInfo');

    const editorModal       = document.getElementById('editorModal');
    const modalTitle        = document.getElementById('modalTitle');
    const modalJson         = document.getElementById('modalJson');
    const closeModalBtn     = document.getElementById('closeModalBtn');
    const saveModalBtn      = document.getElementById('saveModalBtn');
    const fieldModePanel    = document.getElementById('fieldModePanel');
    const switchFieldModeBtn = document.getElementById('switchFieldModeBtn');
    const switchJsonModeBtn = document.getElementById('switchJsonModeBtn');

    const quickUserId       = document.getElementById('quickUserId');
    const quickEmail        = document.getElementById('quickEmail');
    const lockUserBtn       = document.getElementById('lockUserBtn');
    const unlockUserBtn     = document.getElementById('unlockUserBtn');
    const changeEmailBtn    = document.getElementById('changeEmailBtn');
    const regenPlanBtn      = document.getElementById('regenPlanBtn');
    const deleteTodayPlanBtn = document.getElementById('deleteTodayPlanBtn');
    const verifyEmailBtn    = document.getElementById('verifyEmailBtn');
    const unverifyEmailBtn  = document.getElementById('unverifyEmailBtn');
    const resetAttemptsBtn  = document.getElementById('resetAttemptsBtn');
    const shortcutHint      = document.getElementById('shortcutHint');

    const state = {
        page: 1, totalPages: 1, pageSize: 20,
        mode: 'create', editingId: null, items: [],
        currentSchema: [], currentShortcuts: [], editorMode: 'field',
    };

    function setStatus(message, isError = false) {
        statusText.textContent = message;
        statusText.className = isError ? 'error' : '';
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;').replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;').replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    async function fetchJson(url, options = {}) {
        const response = await fetch(url, {
            headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', ...(options.headers || {}) },
            ...options,
        });
        let payload = {};
        try { payload = await response.json(); } catch (_) {}
        if (!response.ok) throw new Error(payload.detail || `Request failed (${response.status})`);
        return payload;
    }

    async function loadCollections() {
        const payload = await fetchJson('/admin/data-manager/api/collections');
        collectionSelect.innerHTML = '';
        payload.collections.forEach((name) => {
            const option = document.createElement('option');
            option.value = name; option.textContent = name;
            collectionSelect.appendChild(option);
        });
    }

    async function loadRecords() {
        const collection = collectionSelect.value;
        if (!collection) return;
        setStatus('Loading records…');
        const payload = await fetchJson(`/admin/data-manager/api/${collection}?page=${state.page}&page_size=${state.pageSize}`);
        state.items = payload.items || [];
        state.totalPages = payload.total_pages || 1;
        renderRecords();
        paginationInfo.textContent = `Page ${payload.page} of ${state.totalPages} · Total ${payload.total}`;
        setStatus('Loaded');
    }

    async function loadCollectionSchema() {
        const collection = collectionSelect.value;
        if (!collection) return;
        const payload = await fetchJson(`/admin/data-manager/api/schema/${collection}`);
        state.currentSchema = payload.fields || [];
        state.currentShortcuts = payload.shortcuts || [];
        applyShortcutVisibility();
    }

    function applyShortcutVisibility() {
        const actions = new Set(state.currentShortcuts.map((s) => s.action));
        lockUserBtn.classList.toggle('hidden', !actions.has('lock'));
        unlockUserBtn.classList.toggle('hidden', !actions.has('unlock'));
        changeEmailBtn.classList.toggle('hidden', !actions.has('change_email'));
        regenPlanBtn.classList.toggle('hidden', !actions.has('regen_plan'));
        deleteTodayPlanBtn.classList.toggle('hidden', !actions.has('delete_today_plan'));
        verifyEmailBtn.classList.toggle('hidden', !actions.has('verify_email'));
        unverifyEmailBtn.classList.toggle('hidden', !actions.has('unverify_email'));
        resetAttemptsBtn.classList.toggle('hidden', !actions.has('reset_login_attempts'));
        shortcutHint.textContent = actions.size
            ? `Shortcuts available for "${collectionSelect.value}"`
            : `No shortcuts available for "${collectionSelect.value}"`;
    }

    function getFieldInputType(type) {
        if (type === 'number') return 'number';
        return 'text';
    }

    function openFieldModePanel(documentData = {}) {
        const fields = state.currentSchema || [];
        if (!fields.length) {
            fieldModePanel.innerHTML = '<p style="font-size:12px;color:var(--text-muted);font-family:\'DM Mono\',monospace;">No schema available. Use JSON mode.</p>';
            return;
        }

        fieldModePanel.innerHTML = fields.map((field) => {
            const value = documentData[field.name];
            const readonly = (state.mode === 'edit' && field.name === '_id') || field.readonly ? 'readonly' : '';

            if (field.type === 'boolean') {
                const checked = value === true ? 'checked' : '';
                return `<label class="checkbox-label">
                    <input data-field-name="${field.name}" data-field-type="boolean" type="checkbox" ${checked} ${readonly} />
                    <span>${field.name}</span>
                </label>`;
            }

            if (field.type === 'enum') {
                const options = (field.options || []).map((opt) =>
                    `<option value="${escapeHtml(opt)}" ${String(value) === String(opt) ? 'selected' : ''}>${escapeHtml(opt)}</option>`
                ).join('');
                return `<div class="field-group-row">
                    <label class="field-label-main">${field.name}</label>
                    <select data-field-name="${field.name}" data-field-type="enum" ${readonly}>
                        <option value=""></option>${options}
                    </select>
                </div>`;
            }

            if (field.type === 'json') {
                const textValue = value === undefined ? '' : JSON.stringify(value, null, 2);
                return `<div class="field-group-row">
                    <label class="field-label-main">${field.name} <span style="opacity:.5;">(JSON)</span></label>
                    <textarea data-field-name="${field.name}" data-field-type="json" rows="4" ${readonly}>${escapeHtml(textValue)}</textarea>
                </div>`;
            }

            const inputValue = value === undefined || value === null ? '' : String(value);
            return `<div class="field-group-row">
                <label class="field-label-main">${field.name}</label>
                <input data-field-name="${field.name}" data-field-type="${field.type || 'string'}"
                    type="${getFieldInputType(field.type)}" value="${escapeHtml(inputValue)}" ${readonly} />
            </div>`;
        }).join('');
    }

    function renderRecords() {
        if (!state.items.length) {
            recordsBody.innerHTML = '<tr class="empty-row"><td colspan="3">No records found</td></tr>';
            return;
        }

        recordsBody.innerHTML = state.items.map((item) => {
            const docString = JSON.stringify(item, null, 2);
            const id = item._id ?? '';
            return `<tr style="vertical-align:top;">
                <td class="mono">${escapeHtml(id)}</td>
                <td><pre class="record-pre">${escapeHtml(docString)}</pre></td>
                <td>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                        <button class="btn btn-ghost btn-sm" data-action="edit" data-id="${escapeHtml(id)}">✎ Edit</button>
                        <button class="btn btn-danger btn-sm" data-action="delete" data-id="${escapeHtml(id)}">✕</button>
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    function openModal(mode, documentData = {}, id = null) {
        state.mode = mode; state.editingId = id;
        modalTitle.textContent = mode === 'create' ? 'Create Document' : 'Update Document';
        modalJson.value = JSON.stringify(documentData, null, 2);
        openFieldModePanel(documentData);

        if (state.editorMode === 'field') {
            fieldModePanel.classList.remove('hidden');
            modalJson.classList.add('hidden');
        } else {
            fieldModePanel.classList.add('hidden');
            modalJson.classList.remove('hidden');
        }

        editorModal.classList.remove('hidden');
        editorModal.classList.add('flex');
    }

    function closeModal() {
        editorModal.classList.remove('flex');
        editorModal.classList.add('hidden');
    }

    async function saveModal() {
        const collection = collectionSelect.value;
        if (!collection) return;

        let parsed;
        if (state.editorMode === 'json') {
            try { parsed = JSON.parse(modalJson.value); } catch (error) {
                setStatus('Invalid JSON in modal', true); return;
            }
            if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {
                setStatus('JSON must be an object', true); return;
            }
        } else {
            parsed = {};
            const controls = fieldModePanel.querySelectorAll('[data-field-name]');
            for (const control of controls) {
                const name = control.getAttribute('data-field-name');
                const type = control.getAttribute('data-field-type');
                if (!name) continue;
                if (type === 'boolean') { parsed[name] = control.checked; continue; }
                const raw = control.value;
                if (raw === '') continue;
                if (type === 'number') { parsed[name] = Number(raw); continue; }
                if (type === 'json') {
                    try { parsed[name] = JSON.parse(raw); } catch (_) {
                        setStatus(`Invalid JSON for field ${name}`, true); return;
                    }
                    continue;
                }
                parsed[name] = raw;
            }
        }

        if (state.mode === 'create') {
            await fetchJson(`/admin/data-manager/api/${collection}`, {
                method: 'POST', body: JSON.stringify({ document: parsed }),
            });
            setStatus('Document created');
        } else {
            await fetchJson(`/admin/data-manager/api/${collection}/${encodeURIComponent(state.editingId)}`, {
                method: 'PUT', body: JSON.stringify({ updates: parsed }),
            });
            setStatus('Document updated');
        }

        closeModal();
        await loadRecords();
    }

    async function deleteRecord(id) {
        const collection = collectionSelect.value;
        if (!collection) return;
        const confirmed = confirm(`Delete document ${id}?`);
        if (!confirmed) return;
        await fetchJson(`/admin/data-manager/api/${collection}/${encodeURIComponent(id)}`, { method: 'DELETE' });
        setStatus('Document deleted');
        await loadRecords();
    }

    async function quickUserAction(path, body = null, successMessage) {
        const userId = quickUserId.value.trim();
        if (!userId) { setStatus('User ID is required for quick action', true); return; }
        const collection = collectionSelect.value;
        const baseCollection = collection === 'credentials' ? 'credentials' : 'users';
        await fetchJson(`/admin/data-manager/api/${baseCollection}/${encodeURIComponent(userId)}${path}`, {
            method: 'POST', body: body ? JSON.stringify(body) : '{}',
        });
        setStatus(successMessage);
    }

    function syncSelectedId(id) { if (!id) return; quickUserId.value = String(id); }

    // ── EVENT LISTENERS ──

    recordsBody.addEventListener('click', async (event) => {
        const button = event.target.closest('button[data-action]');
        if (!button) return;
        const id = button.getAttribute('data-id');
        const action = button.getAttribute('data-action');
        const item = state.items.find((row) => String(row._id) === String(id));
        try {
            if (action === 'edit') { syncSelectedId(id); openModal('edit', item || {}, id); }
            else if (action === 'delete') { await deleteRecord(id); }
        } catch (error) { setStatus(error.message || 'Action failed', true); }
    });

    refreshBtn.addEventListener('click', async () => {
        try { await loadRecords(); } catch (error) { setStatus(error.message || 'Refresh failed', true); }
    });

    createBtn.addEventListener('click', () => {
        if (!state.currentSchema.length) state.editorMode = 'json';
        openModal('create', {});
    });

    collectionSelect.addEventListener('change', async () => {
        state.page = 1;
        try { await loadCollectionSchema(); await loadRecords(); }
        catch (error) { setStatus(error.message || 'Load failed', true); }
    });

    pageSizeSelect.addEventListener('change', async () => {
        state.pageSize = Number(pageSizeSelect.value || '20'); state.page = 1;
        try { await loadRecords(); } catch (error) { setStatus(error.message || 'Load failed', true); }
    });

    prevBtn.addEventListener('click', async () => {
        if (state.page <= 1) return; state.page -= 1;
        try { await loadRecords(); } catch (error) { setStatus(error.message || 'Pagination failed', true); }
    });

    nextBtn.addEventListener('click', async () => {
        if (state.page >= state.totalPages) return; state.page += 1;
        try { await loadRecords(); } catch (error) { setStatus(error.message || 'Pagination failed', true); }
    });

    closeModalBtn.addEventListener('click', closeModal);
    editorModal.addEventListener('click', (e) => { if (e.target === editorModal) closeModal(); });

    switchFieldModeBtn.addEventListener('click', () => {
        state.editorMode = 'field';
        fieldModePanel.classList.remove('hidden');
        modalJson.classList.add('hidden');
    });

    switchJsonModeBtn.addEventListener('click', () => {
        state.editorMode = 'json';
        fieldModePanel.classList.add('hidden');
        modalJson.classList.remove('hidden');
    });

    saveModalBtn.addEventListener('click', async () => {
        try { await saveModal(); } catch (error) { setStatus(error.message || 'Save failed', true); }
    });

    lockUserBtn.addEventListener('click', async () => {
        try { await quickUserAction('/lock', { lock: true }, 'User locked'); }
        catch (error) { setStatus(error.message || 'Lock failed', true); }
    });

    unlockUserBtn.addEventListener('click', async () => {
        try { await quickUserAction('/lock', { lock: false }, 'User unlocked'); }
        catch (error) { setStatus(error.message || 'Unlock failed', true); }
    });

    changeEmailBtn.addEventListener('click', async () => {
        const email = quickEmail.value.trim();
        if (!email) { setStatus('Email is required', true); return; }
        try { await quickUserAction('/email', { email }, 'Email updated'); }
        catch (error) { setStatus(error.message || 'Email update failed', true); }
    });

    regenPlanBtn.addEventListener('click', async () => {
        try { await quickUserAction('/regen-plan', null, 'Plan regenerated'); }
        catch (error) { setStatus(error.message || 'Plan regeneration failed', true); }
    });

    deleteTodayPlanBtn.addEventListener('click', async () => {
        try { await quickUserAction('/delete-today-plan', null, "Deleted today's plan"); }
        catch (error) { setStatus(error.message || 'Delete plan failed', true); }
    });

    verifyEmailBtn.addEventListener('click', async () => {
        const userId = quickUserId.value.trim();
        if (!userId) { setStatus('Credential/User ID is required', true); return; }
        if (collectionSelect.value !== 'credentials') { setStatus('Select credentials collection for verify email', true); return; }
        try {
            await fetchJson(`/admin/data-manager/api/credentials/${encodeURIComponent(userId)}/verify-email`, {
                method: 'POST', body: JSON.stringify({ verified: true }),
            });
            setStatus('Email marked verified');
        } catch (error) { setStatus(error.message || 'Verify email failed', true); }
    });

    unverifyEmailBtn.addEventListener('click', async () => {
        const userId = quickUserId.value.trim();
        if (!userId) { setStatus('Credential/User ID is required', true); return; }
        if (collectionSelect.value !== 'credentials') { setStatus('Select credentials collection for verify email', true); return; }
        try {
            await fetchJson(`/admin/data-manager/api/credentials/${encodeURIComponent(userId)}/verify-email`, {
                method: 'POST', body: JSON.stringify({ verified: false }),
            });
            setStatus('Email marked unverified');
        } catch (error) { setStatus(error.message || 'Unverify email failed', true); }
    });

    resetAttemptsBtn.addEventListener('click', async () => {
        const userId = quickUserId.value.trim();
        if (!userId) { setStatus('Credential/User ID is required', true); return; }
        if (collectionSelect.value !== 'credentials') { setStatus('Select credentials collection for reset attempts', true); return; }
        try {
            await fetchJson(`/admin/data-manager/api/credentials/${encodeURIComponent(userId)}/reset-login-attempts`, {
                method: 'POST', body: '{}',
            });
            setStatus('Login attempts reset');
        } catch (error) { setStatus(error.message || 'Reset login attempts failed', true); }
    });

    async function bootstrap() {
        try {
            await loadCollections();
            await loadCollectionSchema();
            state.pageSize = Number(pageSizeSelect.value || '20');
            await loadRecords();
        } catch (error) { setStatus(error.message || 'Initialization failed', true); }
    }

    bootstrap();
</script>
{% endblock %}